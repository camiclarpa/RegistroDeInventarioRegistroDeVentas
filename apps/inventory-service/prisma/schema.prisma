generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(cuid())
  skuInternal   String   @unique
  barcodeExternal String?
  partNumberOEM String
  brandId       String
  categoryId    String
  nameCommercial String
  descriptionTech String?
  compatibleModels Json     @default("[]")
  imageKey      String?
  locationBin   String
  costPriceAvg  Float
  salePriceBase Float
  taxRate       Float    @default(19)
  stockQuantity Int      @default(0)
  minStockLevel Int      @default(5)
  maxStockLevel Int?
  warrantyDays  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("products")
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brands")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}
