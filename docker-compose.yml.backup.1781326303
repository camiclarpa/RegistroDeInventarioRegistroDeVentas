services:
  db:
    image: postgres:15-alpine
    container_name: sigc_db
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres123
      POSTGRES_DB: sigc_motos
    volumes:
      - sigh_motos_pgdata:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d sigc_motos"]
      interval: 5s
      timeout: 5s
      retries: 10

  app:
    build: .
    container_name: sigc_app
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    env_file:
      - .env.production
    ports:
      - "3001:3000"
    volumes:
      - sigh_motos_uploads:/app/uploads

volumes:
  sigh_motos_pgdata:
    external: true
  sigh_motos_uploads:
    external: true
