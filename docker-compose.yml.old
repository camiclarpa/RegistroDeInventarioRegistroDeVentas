# ═══════════════════════════════════════════════════════════════════════════════
#  SIGC-Motos v2.0 — Docker Compose (Producción)
#  Dominio:   motos.quantacloud.co
#  VPS IP:    79.143.181.220
#  Uso:       docker compose --env-file .env.production up -d
# ═══════════════════════════════════════════════════════════════════════════════

services:

  # ── 1. Base de datos PostgreSQL ──────────────────────────────────────────────
  db:
    image: postgres:15-alpine
    container_name: sigc_db
    restart: unless-stopped
    environment:
      POSTGRES_USER:     ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB:       ${POSTGRES_DB}
    volumes:
      - pgdata:/var/lib/postgresql/data
    expose:
      - "5432"
    networks:
      - sigc-net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-sigc_user} -d ${POSTGRES_DB:-sigc_db}"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s

  # ── 2. Sincronización de Esquema (Reemplaza migrate deploy por db push) ──────
  # CORRECCIÓN: Usamos 'db push' para evitar errores de migración P3005/Schema Engine
  migrate:
    build:
      context: .
      dockerfile: Dockerfile
      target: builder
    container_name: sigc_migrate
    command: npx prisma db push --accept-data-loss
    environment:
      DATABASE_URL: ${DATABASE_URL}
    depends_on:
      db:
        condition: service_healthy
    networks:
      - sigc-net
    restart: "no"

  # ── 3. Backend API Node.js + Prisma ──────────────────────────────────────────
  # CORRECCIÓN: Eliminada dependencia de 'migrate' para arranque inmediato
  app:
    build:
      context: .
      dockerfile: Dockerfile
      target: production
    container_name: sigc_app
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      DATABASE_URL: ${DATABASE_URL}
      NODE_ENV:     production
      PORT:         3000
      JWT_SECRET:   ${JWT_SECRET}
      APP_URL:      ${APP_URL:-https://motos.quantacloud.co}
      BACKUP_DIR:   /backups
    volumes:
      - uploads:/app/uploads
      - ./ssl:/etc/ssl/certs:ro
      - ./logs:/app/logs
      - ./backups:/backups
    expose:
      - "3000"
    networks:
      - sigc-net
    healthcheck:
      test: ["CMD-SHELL", "node -e \"require('http').get('http://localhost:3000/health', r => process.exit(r.statusCode === 200 ? 0 : 1)).on('error', () => process.exit(1))\""]
      interval: 15s
      timeout: 10s
      retries: 5
      start_period: 30s

  # ── 4. Nginx — Reverse Proxy + SSL + SPA ─────────────────────────────────────
  nginx:
    image: nginx:1.27-alpine
    container_name: sigc_nginx
    restart: unless-stopped
    depends_on:
      app:
        condition: service_healthy
    ports:
      - "443:443"
      - "80:80"
      - "443:443"
    volumes:
      - ./docker/nginx/conf.d:/etc/nginx/conf.d
      - ./frontend/dist:/usr/share/nginx/html
      - uploads:/app/uploads
      - ./ssl:/etc/ssl/certs:ro
      - certbot-www:/var/www/certbot
      - certbot-certs:/etc/letsencrypt:ro
      - certbot-certs:/etc/letsencrypt
    networks:
      - sigc-net

  # ── 5. Certbot — Obtención y renovación automática de certificados SSL ────────
  certbot:
    image: certbot/certbot:latest
    container_name: sigc_certbot
    volumes:
      - certbot-certs:/etc/letsencrypt
      - certbot-www:/var/www/certbot
      - certbot-certs:/etc/letsencrypt:ro
    entrypoint: >
      /bin/sh -c "trap exit TERM;
        while :; do
          certbot renew --webroot --webroot-path=/var/www/certbot --quiet;
          sleep 12h &
          wait $${!};
        done"
    networks:
      - sigc-net
    restart: unless-stopped

  # ── 6. Prisma Studio (Temporal para administración de BD) ─────────────────────
  prisma-studio:
    image: node:20-alpine
    container_name: sigc_prisma_studio
    working_dir: /app
    command: sh -c "npm install -g prisma && npx prisma studio --port 5555"
    environment:
      DATABASE_URL: ${DATABASE_URL}
    ports:
      - "443:443"
      - "5555:5555"
    depends_on:
      db:
        condition: service_healthy
    networks:
      - sigc-net
    restart: "no"

# ── Volúmenes persistentes ────────────────────────────────────────────────────
volumes:
  pgdata:
    driver: local
  uploads:
    driver: local
  certbot-www:
    driver: local
  certbot-certs:
    driver: local

# ── Red interna (DB nunca expuesta al exterior) ───────────────────────────────
networks:
  sigc-net:
    driver: bridge
