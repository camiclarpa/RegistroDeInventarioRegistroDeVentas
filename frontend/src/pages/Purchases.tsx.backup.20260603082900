import { useState, useEffect, useCallback } from 'react'
import { useForm, useFieldArray } from 'react-hook-form'
import { zodResolver } from '@hookform/resolvers/zod'
import { Plus, Trash2, ShoppingBag, CheckCircle, XCircle, Eye, Download, Pencil, FileText } from 'lucide-react'
import { toast } from 'sonner'
import { purchaseService } from '@/services/purchaseService'
import { inventoryService } from '@/services/inventoryService'
import type { PurchaseOrder, Supplier, Product } from '@/types'
import { purchaseOrderSchema, supplierSchema, type PurchaseOrderInput, type SupplierInput } from '@/utils/validators'
import { PageHeader } from '@/components/ui/PageHeader'
import { Card } from '@/components/ui/Card'
import { Modal } from '@/components/ui/Modal'
import { ConfirmDialog } from '@/components/ui/ConfirmDialog'
import { Badge } from '@/components/ui/Badge'
import { Pagination } from '@/components/ui/Pagination'
import { TableSkeleton } from '@/components/ui/Skeleton'
import { Spinner } from '@/components/ui/Spinner'
import { EmptyState } from '@/components/ui/EmptyState'
import { SearchInput } from '@/components/ui/SearchInput'
import { formatCOP, formatDate, poStatusBadge } from '@/utils/formatters'
import { exportPurchaseOrdersToExcel } from '@/utils/excelExport'

// Mapeo de estados español (dropdown) → inglés (base de datos)
const statusToEnglish: Record<string, string> = {
  'Pendiente': 'PENDING',
  'Recibida': 'RECEIVED',
  'Cancelada': 'CANCELLED',
  'Parcial': 'PARTIALLY_RECEIVED',
  'Todos los estados': ''
};



const statusOptions = [
  { value: '', label: 'Todos los estados' },
  { value: 'PENDING', label: 'Pendiente' },
  { value: 'RECEIVED', label: 'Recibida' },
  { value: 'CANCELLED', label: 'Cancelada' },
]

export default function Purchases() {
  const [orders, setOrders] = useState<PurchaseOrder[]>([])
  const [suppliers, setSuppliers] = useState<Supplier[]>([])
  const [products, setProducts] = useState<Product[]>([])
  const [total, setTotal] = useState(0)
  const [page, setPage] = useState(1)
  const [totalPages, setTotalPages] = useState(1)
  const [loading, setLoading] = useState(true)
  const [statusFilter, setStatusFilter] = useState('')
  const [supplierFilter, setSupplierFilter] = useState('')

  const [orderModal, setOrderModal] = useState(false)
  const [detailModal, setDetailModal] = useState(false)
  const [supplierModal, setSupplierModal] = useState(false)
  const [deactivateSupplierModal, setDeactivateSupplierModal] = useState(false)
  const [supplierToDeactivate, setSupplierToDeactivate] = useState('')
  const [deactivationReason, setDeactivationReason] = useState('')
  const [supplierStats, setSupplierStats] = useState<any>(null)
  const [loadingStats, setLoadingStats] = useState(false)

  // Cargar estadísticas del proveedor seleccionado
  useEffect(() => {
    if (!supplierToDeactivate) {
      setSupplierStats(null)
      return
    }
    const loadStats = async () => {
      setLoadingStats(true)
      try {
        const stats = await purchaseService.getSupplierStats(supplierToDeactivate)
        setSupplierStats(stats)
      } catch (err) {
        console.error("Error cargando estadísticas:", err)
      } finally {
        setLoadingStats(false)
      }
    }
    loadStats()
  }, [supplierToDeactivate])


  // Cargar estadísticas del proveedor cuando se selecciona uno
  useEffect(() => {
    if (!supplierToDeactivate) {
      setSupplierStats(null)
      return
    }
    const loadStats = async () => {
      setLoadingStats(true)
      try {
        const data = await purchaseService.getSupplierStats(supplierToDeactivate)
        setSupplierStats(data.data || data)
      } catch (err) {
        console.error("Error cargando stats:", err)
        setSupplierStats(null)
      } finally {
        setLoadingStats(false)
      }
    }
    loadStats()
  }, [supplierToDeactivate])
  const [showInactive, setShowInactive] = useState(false)
  const [receiveDialog, setReceiveDialog] = useState(false)
  const [cancelDialog, setCancelDialog] = useState(false)
  const [selectedOrder, setSelectedOrder] = useState<PurchaseOrder | null>(null)
  const [saving, setSaving] = useState(false)
  const [productSearch, setProductSearch] = useState('')
  const [productResults, setProductResults] = useState<Product[]>([])

  const LIMIT = 20

  const { register, handleSubmit, reset, control, watch, formState: { errors } } = useForm<PurchaseOrderInput>({
    resolver: zodResolver(purchaseOrderSchema),
    defaultValues: { supplierId: '', items: [] },
  })

  const { fields, append, remove } = useFieldArray({ control, name: 'items' })

  const { register: regSup, handleSubmit: handleSupSubmit, reset: resetSup, formState: { errors: supErrors } } = useForm<SupplierInput>({
    resolver: zodResolver(supplierSchema),
  })

  const watchItems = watch('items')
  const orderTotal = (watchItems ?? []).reduce((s, i) => s + (Number(i.quantity) * Number(i.unitCost) || 0), 0)

  const load = useCallback(async (p = page, status = statusFilter, sup = supplierFilter) => {
    const statusEn = statusToEnglish[status] || status;
    setLoading(true)
    try {
      const res = await purchaseService.getOrders({ page: p, limit: LIMIT, status: statusEn || undefined, supplierId: sup || undefined })
      setOrders(res.data)
      setTotal(res.total)
      setTotalPages(res.totalPages)
    } catch { /* handled */ } finally { setLoading(false) }
  }, []) // eslint-disable-line react-hooks/exhaustive-deps

  useEffect(() => { load() }, []) // eslint-disable-line react-hooks/exhaustive-deps
  useEffect(() => { purchaseService.getSuppliers().then(setSuppliers).catch(() => {}) }, [])
  useEffect(() => { inventoryService.getProducts({ limit: 500 }).then((r) => setProducts(r.data)).catch(() => {}) }, [])

  const handleProductSearch = async (q: string) => {
    setProductSearch(q)
    if (q.length < 2) { setProductResults([]); return }
    const results = products.filter((p) => p.name.toLowerCase().includes(q.toLowerCase()) || p.sku?.toLowerCase().includes(q.toLowerCase()))
    setProductResults(results.slice(0, 8))
  }

  const addProductToOrder = (product: Product) => {
    const exists = fields.find((f) => f.productId === product.id)
    if (exists) { toast.warning('Este producto ya está en la orden'); return }
    append({ productId: product.id, quantity: 1, unitCost: product.costPrice } as any)
    setProductSearch('')
    setProductResults([])
  }

  const onSaveOrder = async (data: PurchaseOrderInput) => {
    setSaving(true)
    try {
      await purchaseService.createOrder(data as any)
      toast.success('Orden de compra creada')
      setOrderModal(false)
      reset()
      load(1, statusFilter, supplierFilter)
      setPage(1)
    } catch (err: unknown) {
      const msg = (err as { response?: { data?: { message?: string } } })?.response?.data?.message ?? 'Error al crear orden'
      toast.error(msg)
    } finally { setSaving(false) }
  }

  const onSaveSupplier = async (data: SupplierInput) => {
    setSaving(true)
    try {
      const s = await purchaseService.createSupplier(data as any)
      setSuppliers((prev) => [...prev, s])
      toast.success('Proveedor creado')
      setSupplierModal(false)
      resetSup()
    } catch (err: unknown) {
      const msg = (err as { response?: { data?: { message?: string } } })?.response?.data?.message ?? 'Error al crear proveedor'
      toast.error(msg)
    } finally { setSaving(false) }
  }

  const handleReceive = async () => {
    if (!selectedOrder) return
    setSaving(true)
    try {
      await purchaseService.receiveOrder(selectedOrder.id, [])
      toast.success('Orden recibida y stock actualizado')
      setReceiveDialog(false)
      load(page, statusFilter, supplierFilter)
    } catch (err: unknown) {
      const msg = (err as { response?: { data?: { message?: string } } })?.response?.data?.message ?? 'Error al recibir orden'
      toast.error(msg)
    } finally { setSaving(false) }
  }

  
        const handleDeactivateSupplier = async () => {
    if (!supplierToDeactivate) {
      toast.error('Selecciona un proveedor')
      return
    }
    
    const selectedSupplier = suppliers.find((s: any) => s.id === supplierToDeactivate);
    const isInactive = selectedSupplier && !selectedSupplier.isActive;

    setSaving(true)
    try {
      if (isInactive) {
        // Lógica de Reactivación
        await purchaseService.reactivateSupplier(supplierToDeactivate)
        toast.success('Proveedor reactivado exitosamente')
      } else {
        // Lógica de Desactivación
        if (!deactivationReason || deactivationReason.trim().length < 5) {
          toast.error('Debes proporcionar un motivo válido (mínimo 5 caracteres)')
          setSaving(false)
          return
        }
        await purchaseService.deleteSupplier(supplierToDeactivate, deactivationReason)
        toast.success('Proveedor desactivado exitosamente')
      }
      
      setDeactivateSupplierModal(false)
      setSupplierToDeactivate('')
      setDeactivationReason('')
      setShowInactive(false)
      
      const sups = await purchaseService.getSuppliers()
      setSuppliers(sups)
      load(page, statusFilter, supplierFilter)
    } catch (err: unknown) {
      const msg = (err as { response?: { data?: { error?: string } } })?.response?.data?.error ?? 'Error en la operación'
      toast.error(msg)
    } finally { 
      setSaving(false) 
  }
  }

  const handleCancel = async () => {
    if (!selectedOrder) return
    setSaving(true)
    try {
      await purchaseService.cancelOrder(selectedOrder.id, 'Cancelado por el usuario')
      toast.success('Orden cancelada')
      setCancelDialog(false)
      load(page, statusFilter, supplierFilter)
    } catch (err: unknown) {
      const msg = (err as { response?: { data?: { message?: string } } })?.response?.data?.message ?? 'Error al cancelar'
      toast.error(msg)
    } finally { setSaving(false) }
  }


  const handleEditOrder = (order: PurchaseOrder) => {
    if (order.status !== 'PENDING') {
      toast.error('Solo se pueden editar órdenes en estado Pendiente')
      return
    }
    reset({
      supplierId: order.supplierId,
      items: order.items.map(item => ({
        productId: item.productId,
        quantity: item.quantity,
        unitCost: item.unitCost,
      })),
    })
    setSelectedOrder(order)
    setOrderModal(true)
    toast.info('Editando orden - Modifica los campos y guarda')
  }

  const handleDownloadPDF = async (orderId: string) => {
    console.log("🚨 [DEBUG FRONTEND] ID ENVIADO DESDE EL BOTÓN:", orderId);
    if (!orderId || orderId.trim() === '') {
      toast.error('ID de orden no válido')
      return
    }

    const loadingToast = toast.loading('📄 Generando PDF de la orden...')

    try {
      const blob = await purchaseService.downloadOrderPDF(orderId)
      
      if (!blob || blob.size === 0) {
        throw new Error('El archivo PDF recibido está vacío')
      }

      const url = window.URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      
      const order = orders.find(o => o.id === orderId)
      const orderNumber = order?.orderNumber || orderId
      a.download = `orden-compra-${orderNumber}.pdf`
      
      document.body.appendChild(a)
      a.click()
      
      window.URL.revokeObjectURL(url)
      document.body.removeChild(a)
      
      toast.success(`✅ PDF descargado: orden-compra-${orderNumber}.pdf`, { 
        id: loadingToast,
        duration: 4000 
      })
    } catch (error: any) {
      console.error('[handleDownloadPDF] Error:', error)
      
      let message = 'Error al descargar el PDF'
      
      if (error?.response?.status === 401) {
        message = '🔒 Tu sesión ha expirado. Por favor, inicia sesión nuevamente.'
        window.dispatchEvent(new CustomEvent('sigc:unauthorized'))
      } else if (error?.response?.status === 404) {
        message = '❌ La orden no fue encontrada en el servidor.'
      } else if (error?.message?.includes('vacío') || error?.message?.includes('empty')) {
        message = '⚠️ El archivo PDF generado está vacío.'
      } else if (error?.code === 'ECONNABORTED' || error?.message?.includes('timeout')) {
        message = '⏱️ La descarga tardó demasiado. Inténtalo de nuevo.'
      }
      
      toast.error(message, { id: loadingToast, duration: 5000 })
    }
  }

  const poBadgeVariant = (s: string): 'yellow' | 'green' | 'red' | 'orange' | 'gray' => {
    if (s === 'PENDING') return 'yellow'
    if (s === 'RECEIVED') return 'green'
    if (s === 'CANCELLED') return 'red'
    return 'gray'
  }

  const getProductName = (id: string) => products.find((p) => p.id === id)?.name ?? id

  return (
    <div>
      <PageHeader
        title="Compras"
        description="Órdenes de compra y proveedores"
        actions={
          <div className="flex gap-2">
            <button className="btn-outline btn-sm" onClick={() => { resetSup(); setSupplierModal(true) }}>
              <Plus className="w-4 h-4" /> Nuevo Proveedor
            </button>
            <button className="btn-outline btn-sm text-red-600 hover:bg-red-50 hover:text-red-700 border-red-200" onClick={() => setDeactivateSupplierModal(true)}>
              <Trash2 className="w-4 h-4" /> Desactivar Proveedor
            </button>
            <button className="btn-outline btn-sm" onClick={async () => { await exportPurchaseOrdersToExcel(orders); toast.success('Excel exportado') }}>
              <Download className="w-4 h-4" /> Exportar
            </button>
            <button className="btn-primary btn-sm" onClick={() => { reset({ supplierId: '', items: [] }); setOrderModal(true) }}>
              <Plus className="w-4 h-4" /> Nueva Orden
            </button>
          </div>
        }
      />

      {/* Filters */}
      <Card className="mb-4 p-4">
        <div className="flex flex-wrap gap-3 items-end">
          <div>
            <label className="label">Estado</label>
            <select className="input-field w-44" value={statusFilter} onChange={(e) => setStatusFilter(e.target.value)}>
              {statusOptions.map((s) => <option key={s.value} value={s.value}>{s.label}</option>)}
            </select>
          </div>
          <div>
            <label className="label">Proveedor</label>
            <select className="input-field w-52" value={supplierFilter} onChange={(e) => setSupplierFilter(e.target.value)}>
              <option value="">Todos los proveedores</option>
              {suppliers.map((s) => <option key={s.id} value={s.id}>{s.name}</option>)}
            </select>
          </div>
          <button className="btn-secondary btn-sm" onClick={() => { setPage(1); load(1, statusFilter, supplierFilter) }}>Filtrar</button>
          <button className="btn-ghost btn-sm text-gray-500" onClick={() => { setStatusFilter(''); setSupplierFilter(''); setPage(1); load(1, '', '') }}>Limpiar</button>
        </div>
      </Card>

      <Card className="overflow-hidden">
        <div className="overflow-x-auto">
          {loading ? <TableSkeleton rows={8} cols={6} /> : orders.length === 0 ? (
            <EmptyState icon={<ShoppingBag className="w-8 h-8" />} title="Sin órdenes de compra" action={<button className="btn-primary btn-sm" onClick={() => { reset({ supplierId: '', items: [] }); setOrderModal(true) }}><Plus className="w-4 h-4" /> Crear primera orden</button>} />
          ) : (
            <table className="w-full">
              <thead>
                <tr className="bg-gray-50 border-b border-gray-200">
                  <th className="table-th">Número</th>
                  <th className="table-th">Proveedor</th>
                  <th className="table-th">Total</th>
                  <th className="table-th">Estado</th>
                  <th className="table-th">Fecha Esperada</th>
                  <th className="table-th">Acciones</th>
                </tr>
              </thead>
              <tbody>
                {orders.map((o) => {
                  const st = poStatusBadge(o.status)
                  return (
                    <tr key={o.id} className="table-row">
                      <td className="table-td font-mono text-xs font-semibold text-blue-900">{o.orderNumber}</td>
                      <td className="table-td">{o.supplier?.name ?? '—'}</td>
                      <td className="table-td font-semibold">{formatCOP(o.totalAmount)}</td>
                      <td className="table-td"><Badge variant={poBadgeVariant(o.status)}>{st.label}</Badge></td>
                      <td className="table-td text-gray-500 text-xs">{o.expectedDate ? formatDate(o.expectedDate) : '—'}</td>
                      <td className="table-td">
                        <div className="flex items-center gap-1">
                          {/* 👁️ Ver detalle */}
                          <button 
                            onClick={() => { setSelectedOrder(o); setDetailModal(true) }} 
                            className="p-1.5 rounded hover:bg-blue-50 text-blue-600" 
                            title="Ver detalle"
                          >
                            <Eye className="w-4 h-4" />
                          </button>
                          
                          {/* ✏️ Editar - Solo si está PENDIENTE */}
                          <button 
                            onClick={() => handleEditOrder(o)}
                            disabled={o.status !== 'PENDING'}
                            className={`p-1.5 rounded ${o.status === 'PENDING' ? 'hover:bg-amber-50 text-amber-600' : 'opacity-30 cursor-not-allowed text-gray-400'}`}
                            title={o.status === 'PENDING' ? 'Editar orden' : 'Solo editable en estado Pendiente'}
                          >
                            <Pencil className="w-4 h-4" />
                          </button>
                          
                          {/* 📥 Recibir - Solo si está PENDIENTE */}
                          {o.status === 'PENDING' && (
                            <button 
                              onClick={() => { setSelectedOrder(o); setReceiveDialog(true) }} 
                              className="p-1.5 rounded hover:bg-green-50 text-green-600" 
                              title="Marcar como recibida"
                            >
                              <CheckCircle className="w-4 h-4" />
                            </button>
                          )}
                          
                          {/* 📄 Descargar PDF */}
                          <button 
                            onClick={() => handleDownloadPDF(o.id)}
                            className="p-1.5 rounded hover:bg-purple-50 text-purple-600" 
                            title="Descargar PDF"
                          >
                            <FileText className="w-4 h-4" />
                          </button>
                          
                          {/* ❌ Cancelar - Solo si está PENDIENTE */}
                          {o.status === 'PENDING' && (
                            <button 
                              onClick={() => { setSelectedOrder(o); setCancelDialog(true) }} 
                              className="p-1.5 rounded hover:bg-red-50 text-red-500" 
                              title="Cancelar"
                            >
                              <XCircle className="w-4 h-4" />
                            </button>
                          )}
                        </div>
                      </td>
                    </tr>
                  )
                })}
              </tbody>
            </table>
          )}
        </div>
        {!loading && orders.length > 0 && (
          <Pagination page={page} totalPages={totalPages} total={total} limit={LIMIT} onPageChange={(p) => { setPage(p); load(p) }} />
        )}
      </Card>

      {/* New Order Modal */}
      <Modal open={orderModal} onClose={() => setOrderModal(false)} title="Nueva Orden de Compra" size="xl"
        footer={
          <div className="flex justify-end gap-2">
            <button className="btn-outline" onClick={() => setOrderModal(false)}>Cancelar</button>
            <button className="btn-primary" form="order-form" type="submit" disabled={saving || fields.length === 0}>
              {saving && <Spinner size="sm" />} Crear Orden ({formatCOP(orderTotal)})
            </button>
          </div>
        }
      >
        <form id="order-form" onSubmit={handleSubmit(onSaveOrder)} className="space-y-4">
          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="label">Proveedor *</label>
              <select className={`input-field ${errors.supplierId ? 'input-error' : ''}`} {...register('supplierId')}>
                <option value="">Seleccionar proveedor</option>
                {suppliers.map((s) => <option key={s.id} value={s.id}>{s.name}</option>)}
              </select>
              {errors.supplierId && <p className="text-red-500 text-xs mt-1">{errors.supplierId.message}</p>}
            </div>
            <div>
              <label className="label">Fecha Esperada</label>
              <input type="date" className="input-field" {...register('expectedDate')} />
            </div>
          </div>

          {/* Product search */}
          <div>
            <label className="label">Agregar Productos</label>
            <div className="relative">
              <SearchInput value={productSearch} onChange={handleProductSearch} placeholder="Buscar producto por nombre o SKU..." />
              {productResults.length > 0 && (
                <div className="absolute top-full left-0 right-0 bg-white border border-gray-200 rounded-lg shadow-lg z-20 max-h-52 overflow-y-auto mt-1">
                  {productResults.map((p) => (
                    <button key={p.id} type="button" onClick={() => addProductToOrder(p)} className="w-full text-left px-3 py-2 hover:bg-blue-50 text-sm border-b border-gray-50 last:border-0">
                      <span className="font-medium">{p.name}</span>
                      <span className="text-gray-400 ml-2 text-xs">{p.sku}</span>
                      <span className="text-orange-500 ml-2 text-xs font-medium">{formatCOP(p.costPrice)}</span>
                    </button>
                  ))}
                </div>
              )}
            </div>
          </div>

          {/* Items */}
          {fields.length > 0 && (
            <div className="overflow-x-auto">
              <table className="w-full text-sm">
                <thead className="bg-gray-50">
                  <tr>
                    <th className="table-th">Producto</th>
                    <th className="table-th w-24">Cantidad</th>
                    <th className="table-th w-32">Costo Unit.</th>
                    <th className="table-th w-28">Subtotal</th>
                    <th className="table-th w-10"></th>
                  </tr>
                </thead>
                <tbody>
                  {fields.map((field, idx) => {
                    const qty = Number(watchItems?.[idx]?.quantity) || 0
                    const cost = Number(watchItems?.[idx]?.unitCost) || 0
                    return (
                      <tr key={field.id} className="table-row">
                        <td className="table-td">{getProductName(field.productId)}</td>
                        <td className="table-td">
                          <input type="number" min="1" className="input-field text-center py-1 px-2" {...register(`items.${idx}.quantity`, { valueAsNumber: true })} />
                        </td>
                        <td className="table-td">
                          <input type="number" min="0" step="1" className="input-field py-1 px-2" {...register(`items.${idx}.unitCost`, { valueAsNumber: true })} />
                        </td>
                        <td className="table-td font-semibold">{formatCOP(qty * cost)}</td>
                        <td className="table-td">
                          <button type="button" onClick={() => remove(idx)} className="text-red-400 hover:text-red-600 p-1"><Trash2 className="w-4 h-4" /></button>
                        </td>
                      </tr>
                    )
                  })}
                </tbody>
              </table>
            </div>
          )}

          {fields.length === 0 && (
            <div className="text-center py-8 text-gray-400 text-sm border-2 border-dashed border-gray-200 rounded-lg">
              Busca y agrega productos a la orden
            </div>
          )}

          <div>
            <label className="label">Notas</label>
            <textarea className="input-field resize-none" rows={2} {...register('notes')} placeholder="Observaciones opcionales..." />
          </div>
        </form>
      </Modal>

      {/* Detail Modal */}
      <Modal open={detailModal} onClose={() => setDetailModal(false)} title={`Orden ${selectedOrder?.orderNumber ?? ''}`} size="lg"
        footer={<div className="flex justify-end"><button className="btn-outline" onClick={() => setDetailModal(false)}>Cerrar</button></div>}
      >
        {selectedOrder && (
          <div className="space-y-4 text-sm">
            <div className="grid grid-cols-2 gap-3">
              <div><span className="text-gray-500">Proveedor:</span> <span className="font-medium">{selectedOrder.supplier?.name}</span></div>
              <div><span className="text-gray-500">Estado:</span> <Badge variant={poBadgeVariant(selectedOrder.status)}>{poStatusBadge(selectedOrder.status).label}</Badge></div>
              <div><span className="text-gray-500">Total:</span> <span className="font-bold text-orange-500">{formatCOP(selectedOrder.totalAmount)}</span></div>
              {selectedOrder.expectedDate && <div><span className="text-gray-500">Fecha esperada:</span> {formatDate(selectedOrder.expectedDate)}</div>}
            </div>
            <table className="w-full">
              <thead className="bg-gray-50"><tr><th className="table-th">Producto</th><th className="table-th">Cant.</th><th className="table-th">Costo</th><th className="table-th">Subtotal</th></tr></thead>
              <tbody>
                {(selectedOrder.items ?? []).map((item, i) => (
                  <tr key={i} className="table-row">
                    <td className="table-td">{item.product?.name ?? getProductName(item.productId)}</td>
                    <td className="table-td">{item.quantityOrdered}</td>
                    <td className="table-td">{formatCOP(item.unitCost)}</td>
                    <td className="table-td font-semibold">{formatCOP(item.lineTotal)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </Modal>

      {/* New Supplier Modal */}
      <Modal open={supplierModal} onClose={() => { setSupplierModal(false); resetSup() }} title="Nuevo Proveedor" size="sm"
        footer={
          <div className="flex justify-end gap-2">
            <button className="btn-outline" onClick={() => { setSupplierModal(false); resetSup() }}>Cancelar</button>
            <button className="btn-primary" form="sup-form" type="submit" disabled={saving}>
              {saving && <Spinner size="sm" />} Crear
            </button>
          </div>
        }
      >
        <form id="sup-form" onSubmit={handleSupSubmit(onSaveSupplier)} className="space-y-3">
          <div><label className="label">Nombre *</label><input className={`input-field ${supErrors.name ? 'input-error' : ''}`} {...regSup('name')} />{supErrors.name && <p className="text-red-500 text-xs mt-1">{supErrors.name.message}</p>}</div>
          <div><label className="label">NIT</label><input className="input-field" {...regSup('nit')} /></div>
          <div><label className="label">Contacto</label><input className="input-field" {...regSup('contactName')} /></div>
          <div><label className="label">Teléfono</label><input className="input-field" {...regSup('phone')} /></div>
          <div><label className="label">Email</label><input type="email" className="input-field" {...regSup('email')} /></div>
          <div><label className="label">Dirección</label><input className="input-field" {...regSup('address')} /></div>
        </form>
      </Modal>

      {      /* Dual Supplier Modal (Desactivar / Reactivar) */}
      <Modal 
        open={deactivateSupplierModal} 
        onClose={() => { setDeactivateSupplierModal(false); setSupplierToDeactivate(''); setDeactivationReason(''); setShowInactive(false); }} 
        title={(() => {
          const s = suppliers.find((x: any) => x.id === supplierToDeactivate);
          return s && !s.isActive ? 'Reactivar Proveedor' : 'Desactivar Proveedor';
        })()}
        size="md"
        footer={
          <div className="flex justify-end gap-2">
            <button className="btn-outline" onClick={() => { setDeactivateSupplierModal(false); setSupplierToDeactivate(''); setDeactivationReason(''); setShowInactive(false); }}>
              Cancelar
            </button>
            <button 
              className={(() => {
                const s = suppliers.find((x: any) => x.id === supplierToDeactivate);
                return s && !s.isActive ? 'btn-primary' : 'btn-danger';
              })()}
              onClick={handleDeactivateSupplier} 
              disabled={saving || !supplierToDeactivate || (!suppliers.find((x: any) => x.id === supplierToDeactivate)?.isActive && false) || (suppliers.find((x: any) => x.id === supplierToDeactivate)?.isActive && (!deactivationReason || deactivationReason.trim().length < 5))}
            >
              {saving && <Spinner size="sm" />} {(() => {
                const s = suppliers.find((x: any) => x.id === supplierToDeactivate);
                return s && !s.isActive ? 'Reactivar' : 'Desactivar';
              })()}
            </button>
          </div>
        }
      >
        <div className="space-y-4">
          {/* Filtro de Inactivos */}
          <div className="flex items-center gap-2 p-2 bg-gray-50 rounded-md">
            <input 
              type="checkbox" 
              id="showInactive" 
              checked={showInactive} 
              onChange={(e) => { setShowInactive(e.target.checked); setSupplierToDeactivate(''); setDeactivationReason(''); }} 
              className="rounded border-gray-300 text-blue-600 focus:ring-blue-500" 
            />
            <label htmlFor="showInactive" className="text-sm text-gray-700 cursor-pointer">Mostrar proveedores inactivos</label>
          </div>

          {/* Selector de Proveedor con Badge */}
          <div>
            <label className="label">Seleccionar Proveedor *</label>
            <select 
              className="input-field w-full" 
              value={supplierToDeactivate} 
              onChange={(e) => { setSupplierToDeactivate(e.target.value); setDeactivationReason(''); }}
            >
              <option value="">-- Seleccionar Proveedor --</option>
              {suppliers
                .filter((s: any) => showInactive || s.isActive)
                .map((s: any) => (
                  <option key={s.id} value={s.id}>
                    {s.name} {s.isActive ? '' : '⚠️ (Inactivo)'}
                  </option>
                ))}
            </select>
          </div>

          {/* Información Detallada del Proveedor */}
          {supplierToDeactivate && (() => {
            const s = suppliers.find((x: any) => x.id === supplierToDeactivate);
            if (!s) return null;
            return (
              <div className={`border rounded-md p-3 space-y-2 ${!s.isActive ? 'bg-gray-50 border-gray-300' : 'bg-blue-50 border-blue-200'}`}>
                <h4 className="text-sm font-semibold text-gray-700 border-b pb-1 flex items-center gap-2">
                  Información del Proveedor
                  {!s.isActive && <span className="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full">Inactivo</span>}
                </h4>
                <div className="grid grid-cols-2 gap-2 text-xs">
                  <div><span className="font-medium text-gray-500">NIT:</span> <span className="text-gray-800">{s.nit || 'N/A'}</span></div>
                  <div><span className="font-medium text-gray-500">Teléfono:</span> <span className="text-gray-800">{s.phone || 'N/A'}</span></div>
                  <div className="col-span-2"><span className="font-medium text-gray-500">Email:</span> <span className="text-gray-800">{s.email || 'N/A'}</span></div>
                  <div className="col-span-2"><span className="font-medium text-gray-500">Condiciones de Pago:</span> <span className="text-gray-800">{s.paymentTerms || 'N/A'}</span></div>
                  {/* Estadísticas del Proveedor */}
                  {loadingStats ? (
                    <div className="col-span-2 flex items-center justify-center py-3">
                      <div className="animate-spin rounded-full h-5 w-5 border-b-2 border-blue-600"></div>
                      <span className="ml-2 text-xs text-gray-500">Cargando estadísticas...</span>
                    </div>
                  ) : supplierStats ? (
                    <div className="col-span-2 mt-3 p-3 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg border border-blue-200">
                      <h5 className="text-xs font-bold text-blue-800 mb-2 flex items-center gap-1">
                        📊 Estadísticas de Compras
                      </h5>
                      <div className="grid grid-cols-2 gap-3 text-xs">
                        <div className="bg-white rounded p-2 border border-blue-100">
                          <p className="text-gray-500 text-[10px] uppercase">Total Órdenes</p>
                          <p className="font-bold text-blue-900 text-lg">{supplierStats.totalOrders}</p>
                        </div>
                        <div className="bg-white rounded p-2 border border-blue-100">
                          <p className="text-gray-500 text-[10px] uppercase">Monto Total</p>
                          <p className="font-bold text-green-700 text-lg">{formatCOP(supplierStats.totalAmount)}</p>
                        </div>
                        <div className="bg-white rounded p-2 border border-blue-100">
                          <p className="text-gray-500 text-[10px] uppercase">Última Orden</p>
                          <p className="font-semibold text-gray-800 text-xs">
                            {supplierStats.lastOrderDate ? formatDate(supplierStats.lastOrderDate) : 'Sin órdenes'}
                          </p>
                          {supplierStats.lastOrderNumber && (
                            <p className="text-[10px] text-gray-500 font-mono">{supplierStats.lastOrderNumber}</p>
                          )}
                        </div>
                        <div className="bg-white rounded p-2 border border-blue-100">
                          <p className="text-gray-500 text-[10px] uppercase mb-1">Estado de Órdenes</p>
                          <div className="flex flex-wrap gap-1">
                            {supplierStats.ordersByStatus.PENDING > 0 && (
                              <span className="badge-yellow text-[9px] px-1.5 py-0.5">
                                {supplierStats.ordersByStatus.PENDING} Pend.
                              </span>
                            )}
                            {supplierStats.ordersByStatus.RECEIVED > 0 && (
                              <span className="badge-green text-[9px] px-1.5 py-0.5">
                                {supplierStats.ordersByStatus.RECEIVED} Rec.
                              </span>
                            )}
                            {supplierStats.ordersByStatus.CANCELLED > 0 && (
                              <span className="badge-red text-[9px] px-1.5 py-0.5">
                                {supplierStats.ordersByStatus.CANCELLED} Canc.
                              </span>
                            )}
                            {supplierStats.ordersByStatus.PARTIALLY_RECEIVED > 0 && (
                              <span className="badge-orange text-[9px] px-1.5 py-0.5">
                                {supplierStats.ordersByStatus.PARTIALLY_RECEIVED} Parc.
                              </span>
                            )}
                            {supplierStats.totalOrders === 0 && (
                              <span className="text-gray-400 text-[10px]">Sin órdenes</span>
                            )}
                          </div>
                        </div>
                      </div>
                      {supplierStats.ordersByStatus.PENDING > 0 && (
                        <div className="mt-2 p-2 bg-yellow-50 border border-yellow-200 rounded text-[10px] text-yellow-800">
                          ⚠️ Este proveedor tiene {supplierStats.ordersByStatus.PENDING} orden(es) pendiente(s). No se puede desactivar hasta que las reciba o cancele.
                        </div>
                      )}
                    </div>
                  ) : null}
                </div>
              </div>
            );
          })()}

          {/* Campo de Motivo (Solo para Desactivar) */}
          {supplierToDeactivate && suppliers.find((x: any) => x.id === supplierToDeactivate)?.isActive && (
            <div>
              <label className="label">Motivo de Desactivación *</label>
              <textarea
                className={`input-field w-full min-h-[80px] ${deactivationReason && deactivationReason.trim().length < 5 ? 'border-red-300 focus:ring-red-500' : ''}`}
                placeholder="Ej: Proveedor dejó de cumplir con los tiempos de entrega..."
                value={deactivationReason}
                onChange={(e) => setDeactivationReason(e.target.value)}
                maxLength={250}
              />
              <p className={`text-xs mt-1 ${deactivationReason && deactivationReason.trim().length < 5 ? 'text-red-500' : 'text-gray-400'}`}>
                {deactivationReason.length}/250 caracteres (mínimo 5)
              </p>
            </div>
          )}
        </div>
      </Modal>

      <ConfirmDialog open={receiveDialog} title="Recibir Orden" message={`¿Confirmar recepción de la orden ${selectedOrder?.orderNumber}? El stock se actualizará automáticamente.`} confirmLabel="Sí, Recibir" variant="info" loading={saving} onConfirm={handleReceive} onCancel={() => setReceiveDialog(false)} />
      <ConfirmDialog open={cancelDialog} title="Cancelar Orden" message={`¿Cancelar la orden ${selectedOrder?.orderNumber}?`} confirmLabel="Sí, Cancelar" loading={saving} onConfirm={handleCancel} onCancel={() => setCancelDialog(false)} />

      </div>
    )
}
