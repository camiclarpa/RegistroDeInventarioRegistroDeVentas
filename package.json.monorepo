{
  "name": "sigc-motos-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "clean": "turbo clean",
    "dev:auth": "cd apps/auth-service && npm run dev",
    "dev:inventory": "cd apps/inventory-service && npm run dev",
    "dev:sales": "cd apps/sales-service && npm run dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
