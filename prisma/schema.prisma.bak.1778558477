generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum MovementType {
  ENTRY // Compra / recepción de mercancía
  EXIT // Salida por venta o despacho
  ADJUSTMENT_POS // Ajuste positivo (conteo físico)
  ADJUSTMENT_NEG // Ajuste negativo (conteo físico)
  MERMA // Pérdida / daño irrecuperable
  RETURN // Devolución de cliente o proveedor
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
  CREDIT // Venta/compra a crédito — genera CxC o CxP
  NEQUI
  DAVIPLATA
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PurchaseOrderStatus {
  PENDING // Creada, sin recibir nada
  PARTIALLY_RECEIVED // Se recibió parte
  RECEIVED // Completamente recibida
  CANCELLED // Cancelada (solo desde PENDING)
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum TransactionType {
  INCOME // Entrada genérica (ej: venta de contado)
  EXPENSE // Gasto operativo (luz, agua, almuerzo)
  WITHDRAWAL // Retiro del dueño
  DEPOSIT // Depósito bancario desde caja
  PAYMENT_RECEIVED // Abono de cliente a su deuda (CxC)
  PAYMENT_MADE // Pago a proveedor (CxP)
}

enum AccountStatus {
  PENDING // Deuda sin ningún abono
  PARTIALLY_PAID // Con abonos pero saldo pendiente
  PAID // Saldada completamente
  OVERDUE // Vencida (dueDate superado y no pagada)
}

// Enums para Tesorería Bancaria (Módulo 7)
enum DepositStatus {
  PENDING // Preparado para llevar al banco
  IN_TRANSIT // Enviado al banco, pendiente confirmación
  RECONCILED // Confirmado en extracto bancario
  REJECTED // Rechazado por el banco
}

enum WithholdingType {
  RETEFUENTE_35 // Retención en la fuente servicios 3.5%
  RETEFUENTE_10 // Retención en la fuente honorarios 10%
  RETEIVA_15 // Retención de IVA 15%
  RETEICA_01 // Retención de ICA ~0.01%
}

enum ExpenseCategory {
  OPERATIVO // Servicios públicos, arriendo, suministros, nómina
  FINANCIERO // Comisiones bancarias, intereses de mora
  IMPUESTO // Retenciones, declaraciones tributarias
  INVERSION // Activos fijos, maquinaria, herramientas
  VARIOS // Otros gastos no clasificados
}

enum CashCountType {
  OPENING // Conteo de apertura de turno
  CLOSING // Conteo de cierre (CIEGO — cajero no ve saldo esperado)
  SURPRISE // Arqueo sorpresa solicitado por administrador
  MIDDAY // Conteo parcial en horario de operación
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 1 — INVENTARIO
// ═══════════════════════════════════════════════════════════════════════════

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("brands")
}

model Category {
  id               String   @id @default(cuid())
  name             String   @unique
  slug             String   @unique
  codePrefix       String   @db.VarChar(6)
  marginPercentage Decimal  @default(30.00) @db.Decimal(5, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id String @id @default(cuid())

  skuInternal     String  @unique
  barcodeExternal String? @unique
  partNumberOEM   String

  brandId    String
  categoryId String
  brand      Brand    @relation(fields: [brandId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  nameCommercial   String
  descriptionTech  String?
  compatibleModels Json    @default("[]")
  imageKey         String?

  locationBin String

  costPriceAvg  Decimal @default(0.00) @db.Decimal(12, 4)
  salePriceBase Decimal @default(0.00) @db.Decimal(12, 2)
  taxRate       Decimal @default(19.00) @db.Decimal(5, 2)

  stockQuantity Int  @default(0)
  minStockLevel Int  @default(5)
  maxStockLevel Int?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements          InventoryMovement[]
  saleItems          SaleItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([skuInternal])
  @@index([barcodeExternal])
  @@index([brandId, categoryId])
  @@map("products")
}

model InventoryMovement {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  type             MovementType
  quantity         Int
  unitCostAtMoment Decimal      @db.Decimal(12, 4)

  referenceDoc      String?
  reason            String?
  performedByUserId String?

  timestamp DateTime @default(now())

  @@index([productId, timestamp])
  @@map("inventory_movements")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 2 — VENTAS / POS
// ═══════════════════════════════════════════════════════════════════════════

model Customer {
  id                   String    @id @default(cuid())
  name                 String
  phone                String?
  email                String?
  identificationNumber String?   @unique
  address              String?
  isActive             Boolean   @default(true)
  // CRM - Fidelización
  loyaltyPoints        Int       @default(0) @map("loyalty_points")
  loyaltyTier          String    @default("BRONZE") @map("loyalty_tier")
  totalSpent           Decimal   @default(0) @map("total_spent") @db.Decimal(15, 2)
  lastPurchaseAt       DateTime? @map("last_purchase_at")
  purchaseCount        Int       @default(0) @map("purchase_count")
  creditLimit          Decimal?  @map("credit_limit") @db.Decimal(15, 2)
  preferences          String?   @map("preferences")
  notes                String?   @map("notes")
  tags                 String[]  @default([]) @map("tags")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales              Sale[]
  accountsReceivable AccountReceivable[]
  // CRM - Relaciones inversas
  motorcycles        Motorcycle[]
  warranties         Warranty[]
  logs               CommunicationLog[]
  reminders          Reminder[]
  communications     Communication[]
  tickets            Ticket[]
  quotes             Quote[]
  workshopVisits     WorkshopVisit[]

  @@index([phone])
  @@index([identificationNumber])
  @@map("customers")
}

model Sale {
  id         String @id @default(cuid())
  saleNumber String @unique

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  userId String

  subtotal       Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0.00) @db.Decimal(12, 2)
  taxAmount      Decimal @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  paymentMethod PaymentMethod
  status        SaleStatus    @default(COMPLETED)
  sentToDian    Boolean       @default(false)
  sentToDianAt  DateTime?
  dianResponse  Json?
  notes         String?       @map("notes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items             SaleItem[]
  accountReceivable AccountReceivable?
  // CRM - Relación con moto
  motorcycleId      String?
  motorcycle        Motorcycle?        @relation(fields: [motorcycleId], references: [id])

  @@index([saleNumber])
  @@index([customerId])
  @@index([userId])
  @@index([status, createdAt])
  @@map("sales")
}

model SaleItem {
  id     String @id @default(cuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productNameSnapshot String
  skuSnapshot         String

  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)
  discountPerItem Decimal @default(0.00) @db.Decimal(12, 2)
  lineTotal       Decimal @db.Decimal(12, 2)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 3 — COMPRAS Y PROVEEDORES
// ═══════════════════════════════════════════════════════════════════════════

model Supplier {
  id            String   @id @default(cuid())
  name          String
  nit           String?  @unique
  phone         String?
  email         String?
  address       String?
  contactPerson String?
  paymentTerms  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  accountsPayable AccountPayable[]

  @@index([nit])
  @@index([name])
  @@map("suppliers")
}

model PurchaseOrder {
  id          String @id @default(cuid())
  orderNumber String @unique

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  userId String

  status PurchaseOrderStatus @default(PENDING)

  subtotal    Decimal @db.Decimal(12, 2)
  taxAmount   Decimal @db.Decimal(12, 2)
  totalAmount Decimal @db.Decimal(12, 2)

  expectedDate DateTime?
  receivedDate DateTime?

  notes String? @map("notes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          PurchaseOrderItem[]
  accountPayable AccountPayable?

  @@index([orderNumber])
  @@index([supplierId])
  @@index([status, createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productNameSnapshot String
  skuSnapshot         String

  quantityOrdered  Int
  quantityReceived Int @default(0)

  unitCost  Decimal @db.Decimal(12, 4)
  lineTotal Decimal @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 5 — USUARIOS, SEGURIDAD Y AUDITORÍA (RBAC)
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs             AuditLog[]
  systemAudits          SystemAudit[]
  openedRegisters       CashRegister[]         @relation("CashRegisterOpenedBy")
  closedRegisters       CashRegister[]         @relation("CashRegisterClosedBy")
  financialTransactions FinancialTransaction[] @relation("FinTxPerformedBy")
  approvedTransactions  FinancialTransaction[] @relation("FinTxApprovedBy")
  paymentRecords        PaymentRecord[]        @relation("PaymentPerformedBy")

  // Relaciones con nuevos modelos de tesorería
  cashCountsMade       CashCount[]    @relation("CashCountPerformedBy")
  cashCountsApproved   CashCount[]    @relation("CashCountApprovedBy")
  bankDepositsCreated  BankDeposit[]  @relation("BankDepositCreatedBy")
  bankDepositsApproved BankDeposit[]  @relation("BankDepositApprovedBy")
  bankTransfers        BankTransfer[] @relation("BankTransferCreatedBy")
  budgets              Budget[]       @relation("BudgetCreatedBy")

  @@index([email])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   Json     @default("{}")
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 6 — GESTIÓN FINANCIERA, CAJA Y CUENTAS POR COBRAR/PAGAR
// ═══════════════════════════════════════════════════════════════════════════

model CashRegister {
  id             String  @id @default(cuid())
  openedByUserId String
  closedByUserId String?
  openedBy       User    @relation("CashRegisterOpenedBy", fields: [openedByUserId], references: [id])
  closedBy       User?   @relation("CashRegisterClosedBy", fields: [closedByUserId], references: [id])

  openingBalance         Decimal  @db.Decimal(12, 2)
  closingBalance         Decimal? @db.Decimal(12, 2)
  expectedClosingBalance Decimal? @db.Decimal(12, 2)
  difference             Decimal? @db.Decimal(12, 2)

  status   CashRegisterStatus @default(OPEN)
  openedAt DateTime           @default(now())
  closedAt DateTime?
  notes    String?            @map("notes")

  transactions FinancialTransaction[]

  // Relaciones con nuevos modelos de tesorería
  cashCounts   CashCount[]
  bankDeposits BankDeposit[]

  @@index([status])
  @@index([openedByUserId])
  @@map("cash_registers")
}

model FinancialTransaction {
  id             String       @id @default(cuid())
  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  description String
  category    String

  // Clasificación de gastos (Pilar 5)
  expenseCategory ExpenseCategory?

  referenceType String?
  referenceId   String?

  paymentMethod PaymentMethod @default(CASH)

  // Comisión bancaria calculada automáticamente (Pilar 3)
  bankingCommission Decimal? @db.Decimal(12, 2)

  // Flujo de aprobaciones por límite (Pilar 5)
  requiresApproval Boolean   @default(false)
  approvedByUserId String?
  approvedBy       User?     @relation("FinTxApprovedBy", fields: [approvedByUserId], references: [id])
  approvedAt       DateTime?

  performedByUserId String
  performedBy       User   @relation("FinTxPerformedBy", fields: [performedByUserId], references: [id])

  timestamp DateTime @default(now())

  // Retención en la fuente asociada (Pilar 4)
  taxWithholding TaxWithholding?

  @@index([cashRegisterId])
  @@index([type])
  @@index([timestamp])
  @@index([expenseCategory])
  @@map("financial_transactions")
}

model AccountReceivable {
  id         String   @id @default(cuid())
  saleId     String   @unique
  sale       Sale     @relation(fields: [saleId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  totalDebt        Decimal @db.Decimal(12, 2)
  paidAmount       Decimal @default(0.00) @db.Decimal(12, 2)
  remainingBalance Decimal @db.Decimal(12, 2)

  dueDate DateTime?
  status  AccountStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments PaymentRecord[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_receivable")
}

model AccountPayable {
  id              String        @id @default(cuid())
  purchaseOrderId String        @unique
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])

  totalDebt        Decimal @db.Decimal(12, 2)
  paidAmount       Decimal @default(0.00) @db.Decimal(12, 2)
  remainingBalance Decimal @db.Decimal(12, 2)

  dueDate DateTime?
  status  AccountStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments PaymentRecord[]

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_payable")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 8 — CONFIGURACIÓN DEL NEGOCIO (singleton)
// ═══════════════════════════════════════════════════════════════════════════

model BusinessConfig {
  id             String   @id @default("main")
  businessName   String   @default("TALLER Y REPUESTOS CLAVIJOS MOTOS")
  nit            String   @default("900.XXX.XXX-X")
  address        String   @default("CRA 16 6-40 AGUACHICA CESAR")
  phone          String   @default("3117379097")
  email          String?
  logoKey        String?
  taxRate        Decimal  @default(19.00) @db.Decimal(5, 2)
  resolutionDian String?
  footer         String   @default("¡Gracias por su compra! Garantía según política de fábrica.")
  updatedAt      DateTime @updatedAt

  @@map("business_config")
}

model PaymentRecord {
  id                  String             @id @default(cuid())
  accountReceivableId String?
  accountReceivable   AccountReceivable? @relation(fields: [accountReceivableId], references: [id])
  accountPayableId    String?
  accountPayable      AccountPayable?    @relation(fields: [accountPayableId], references: [id])

  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  referenceDoc  String?
  note          String?

  performedByUserId String
  performedBy       User   @relation("PaymentPerformedBy", fields: [performedByUserId], references: [id])

  timestamp DateTime @default(now())

  @@index([accountReceivableId])
  @@index([accountPayableId])
  @@map("payment_records")
}

// ═══════════════════════════════════════════════════════════════════════════
// MÓDULO 7 — TESORERÍA BANCARIA (8 Pilares)
// ═══════════════════════════════════════════════════════════════════════════

// ─── Pilar 1: Conteo Ciego (Blind Count Anti-Fraude) ───────────────────────
model CashCount {
  id             String       @id @default(cuid())
  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  countedByUserId String
  countedBy       User   @relation("CashCountPerformedBy", fields: [countedByUserId], references: [id])

  approvedByUserId String?
  approvedBy       User?   @relation("CashCountApprovedBy", fields: [approvedByUserId], references: [id])

  type CashCountType @default(CLOSING)

  denominations Json    @default("[]")
  totalCounted  Decimal @db.Decimal(12, 2)

  systemExpected   Decimal @db.Decimal(12, 2)
  difference       Decimal @db.Decimal(12, 2)
  differenceStatus String?

  isBlindCount     Boolean @default(true)
  requiresApproval Boolean @default(false)

  observations String?
  countedAt    DateTime @default(now())

  @@index([cashRegisterId])
  @@index([countedAt])
  @@index([type])
  @@map("cash_counts")
}

// ─── Pilar 2: Depósitos Bancarios ───────────────────────────────────────────
model BankDeposit {
  id             String        @id @default(cuid())
  cashRegisterId String?
  cashRegister   CashRegister? @relation(fields: [cashRegisterId], references: [id])

  amount          Decimal @db.Decimal(12, 2)
  bankName        String
  accountNumber   String?
  reference       String?
  receiptImageKey String?

  status       DepositStatus @default(PENDING)
  depositDate  DateTime
  reconciledAt DateTime?

  notes String? @map("notes")

  createdByUserId String
  createdBy       User   @relation("BankDepositCreatedBy", fields: [createdByUserId], references: [id])

  approvedByUserId String?
  approvedBy       User?   @relation("BankDepositApprovedBy", fields: [approvedByUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([status])
  @@index([depositDate])
  @@index([bankName])
  @@map("bank_deposits")
}

// ─── Pilar 2: Transferencias Interbancarias ─────────────────────────────────
model BankTransfer {
  id          String  @id @default(cuid())
  fromAccount String
  toAccount   String
  amount      Decimal @db.Decimal(12, 2)
  reference   String?
  description String

  createdByUserId String
  createdBy       User   @relation("BankTransferCreatedBy", fields: [createdByUserId], references: [id])

  transferDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([transferDate])
  @@map("bank_transfers")
}

// ─── Pilar 4: Retenciones en la Fuente ──────────────────────────────────────
model TaxWithholding {
  id            String               @id @default(cuid())
  transactionId String               @unique
  transaction   FinancialTransaction @relation(fields: [transactionId], references: [id])

  type              WithholdingType
  percentage        Decimal         @db.Decimal(5, 2)
  baseAmount        Decimal         @db.Decimal(12, 2)
  withholdingAmount Decimal         @db.Decimal(12, 2)
  netAmount         Decimal         @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("tax_withholdings")
}

// ─── Pilar 5: Presupuesto por Categoría ─────────────────────────────────────
model Budget {
  id       String          @id @default(cuid())
  category ExpenseCategory
  amount   Decimal         @db.Decimal(12, 2)
  month    Int
  year     Int
  alertAt  Int             @default(80)

  createdByUserId String
  createdBy       User   @relation("BudgetCreatedBy", fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, month, year])
  @@index([month, year])
  @@map("budgets")
}

// ── MÓDULO 6-CRM — FIDELIZACIÓN Y GESTIÓN DE CLIENTES ──────────────────────

model Motorcycle {
  id             String          @id @default(cuid())
  plate          String          @unique
  brand          String
  model          String
  year           Int?
  lastKm         Int?            @map("last_km")
  customerId     String          @map("customer_id")
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sales          Sale[]
  createdAt      DateTime        @default(now()) @map("created_at")
  workshopVisits WorkshopVisit[]

  @@index([customerId])
  @@index([plate])
  @@map("motorcycles")
}

model Warranty {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id])
  saleItemId  String   @map("sale_item_id")
  productName String   @map("product_name")
  days        Int
  expiresAt   DateTime @map("expires_at")
  status      String   @default("ACTIVE")
  claimNotes  String?  @map("claim_notes")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([status, expiresAt])
  @@map("warranties")
}

model CommunicationLog {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id])
  type        String
  message     String
  performedBy String   @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([type])
  @@map("communication_logs")
}

model Reminder {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String
  message    String
  dueDate    DateTime @map("due_date")
  isSent     Boolean  @default(false) @map("is_sent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([isSent, dueDate])
  @@map("reminders")
}

// ==========================================
// MÓDULOS CRM PRO (NUEVOS)
// ==========================================

model Communication {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  channel      String
  direction    String    @default("OUTBOUND")
  message      String
  status       String    @default("SENT")
  isRead       Boolean   @default(false)
  sentByUserId String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([customerId, channel, status])
  @@map("communications")
}

model Ticket {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  subject     String
  description String
  status      String    @default("OPEN")
  priority    String    @default("MEDIUM")
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([customerId, status])
  @@map("tickets")
}

model Quote {
  id          String          @id @default(cuid())
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id])
  items       Json            @default("[]")
  subtotal    Decimal         @db.Decimal(12, 2)
  discount    Decimal         @default(0.00) @db.Decimal(12, 2)
  total       Decimal         @db.Decimal(12, 2)
  status      String          @default("DRAFT")
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  deliveries  QuoteDelivery[]

  @@index([customerId, status])
  @@map("quotes")
}

model QuoteDelivery {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id])
  channel     String
  link        String?
  attemptedBy String
  createdAt   DateTime @default(now())

  @@index([quoteId])
  @@map("quote_deliveries")
}

model WorkshopVisit {
  id           String      @id @default(cuid())
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  motorcycleId String?
  motorcycle   Motorcycle? @relation(fields: [motorcycleId], references: [id])
  kmReal       Int?
  services     String[]    @default([])
  technician   String?
  totalCost    Decimal     @db.Decimal(12, 2)
  status       String      @default("COMPLETED")
  notes        String?
  createdAt    DateTime    @default(now())

  @@index([customerId, createdAt])
  @@map("workshop_visits")
}

model SystemBackup {
  id          String    @id @default(cuid())
  type        String    @default("FULL")
  status      String    @default("PENDING")
  size        Decimal?
  checksum    String?
  storageUrl  String?
  triggeredBy String
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
  @@map("system_backups")
}

model SystemAudit {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, action, createdAt])
  @@map("system_audits")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}
