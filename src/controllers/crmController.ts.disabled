export async function listWorkshopVisitsHandler(req: Request, res: Response) {
  try {
    const page = Math.max(1, parseInt(String(req.query['page'] ?? '1')));
    const limit = Math.min(100, parseInt(String(req.query['limit'] ?? '20')));
    const customerId = req.query['customerId'] as string | undefined;
    
    const result = await listWorkshopVisits({ page, limit, customerId });
    return res.json(result);
  } catch (err) { return handleError(res, err, 'listWorkshopVisitsHandler'); }
}

export async function createWorkshopVisitHandler(req: Request, res: Response) {
  try {
    const { customerId, motorcycleId, kmReal, services, technician, totalCost, notes, nextServiceKm } = req.body;
    const result = await createWorkshopVisit({
      customerId,
      motorcycleId,
      kmReal,
      services,
      technician,
      totalCost,
      notes,
      nextServiceKm,
    });
    return res.status(201).json(result);
  } catch (err) { return handleError(res, err, 'createWorkshopVisitHandler'); }
}

export async function getWorkshopVisitHandler(req: Request, res: Response) {
  try {
    const customerId = getParam(req, 'id');
    const result = await getWorkshopSummary(customerId);
    return res.json(result);
  } catch (err) { return handleError(res, err, 'getWorkshopVisitHandler'); }
}
