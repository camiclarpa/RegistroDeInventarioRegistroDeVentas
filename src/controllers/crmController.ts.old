import { Request, Response } from 'express';
import { z } from 'zod';
import { PaymentMethod } from '@prisma/client';
import { logger } from '../config/logger';
import {
  searchCustomersCRM, listCustomersCRM, getCustomer360,
  addCommunicationLog, calculateLoyalty, addMotorcycle,
  updateMotorcycle, createReminder,
} from '../services/crmService';
import {
  checkCreditLimit, createReceivableFromSale, recordPayment,
  getCustomerCredits, updateCreditLimit,
} from '../services/creditService';
import {
  getActiveWarranties, getAllWarranties, markWarrantyClaimed,
} from '../services/warrantyService';
import { createOrUpdateCustomer, updateCustomer } from '../services/customerService';

// Helper: extraer string seguro de req.params (maneja string | string[])
function getParam(req: Request, key: string): string {
  const val = req.params[key];
  return Array.isArray(val) ? val[0] : String(val ?? '');
}

function getUserId(req: Request): string {
  return (req as any).user?.id ?? 'system';
}

function handleError(res: Response, err: unknown, context: string) {
  const message = err instanceof Error ? err.message : 'Error interno';
  const code = (err as any)?.code;
  logger.error(`[crmController] ${context}:`, err);
  if (code === 'CREDIT_LIMIT_EXCEEDED') return res.status(400).json({ error: message, code });
  if (message.includes('no encontrado') || message.includes('not found')) return res.status(404).json({ error: message });
  return res.status(500).json({ error: message });
}

// Schemas Zod
const createCustomerSchema = z.object({
  name: z.string().min(2), phone: z.string().min(7).optional(),
  email: z.string().email().optional(), identificationNumber: z.string().optional(),
  address: z.string().optional(), notes: z.string().optional(),
  preferences: z.string().optional(), tags: z.array(z.string()).optional(),
  creditLimit: z.number().positive().optional(),
});
const updateCustomerSchema = createCustomerSchema.partial();
const createCreditSchema = z.object({
  saleId: z.string().cuid(), customerId: z.string().cuid(),
  totalAmount: z.number().positive(),
  dueDate: z.string().datetime({ offset: true }).or(z.string().regex(/^\d{4}-\d{2}-\d{2}$/)),
});
const paymentSchema = z.object({
  amount: z.number().positive(), paymentMethod: z.nativeEnum(PaymentMethod),
  notes: z.string().optional(), cashRegisterId: z.string().optional(),
});
const motorcycleSchema = z.object({
  plate: z.string().min(3).max(10), brand: z.string().min(2), model: z.string().min(1),
  year: z.number().int().min(1990).max(2030).optional(), lastKm: z.number().int().min(0).optional(),
});
const reminderSchema = z.object({ type: z.string().min(2), message: z.string().min(3), dueDate: z.string() });
const claimSchema = z.object({ notes: z.string().min(3) });
const communicationSchema = z.object({ customerId: z.string().cuid(), type: z.string().min(2), message: z.string().min(3) });

// HANDLERS
export async function searchCustomers(req: Request, res: Response) {
  try {
    const q = String(req.query['q'] ?? '').trim();
    if (q.length < 2) return res.json([]);
    return res.json(await searchCustomersCRM(q));
  } catch (err) { return handleError(res, err, 'searchCustomers'); }
}
export async function listCustomers(req: Request, res: Response) {
  try {
    const page = Math.max(1, parseInt(String(req.query['page'] ?? '1')));
    const limit = Math.min(100, parseInt(String(req.query['limit'] ?? '20')));
    const tier = req.query['tier'] as string | undefined;
    const search = req.query['search'] as string | undefined;
    return res.json(await listCustomersCRM({ page, limit, tier, search }));
  } catch (err) { return handleError(res, err, 'listCustomers'); }
}
export async function getCustomerDetail(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const customer = await getCustomer360(id);
    if (!customer) return res.status(404).json({ error: 'Cliente no encontrado' });
    return res.json(customer);
  } catch (err) { return handleError(res, err, 'getCustomerDetail'); }
}
export async function createCustomer(req: Request, res: Response) {
  try {
    const data = createCustomerSchema.parse(req.body);
    return res.status(201).json(await createOrUpdateCustomer(data));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'createCustomer');
  }
}
export async function patchCustomer(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const data = updateCustomerSchema.parse(req.body);
    return res.json(await updateCustomer(id, data));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'patchCustomer');
  }
}
export async function setCreditLimit(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const { limit } = req.body as { limit: number | null };
    return res.json(await updateCreditLimit(id, limit, getUserId(req)));
  } catch (err) { return handleError(res, err, 'setCreditLimit'); }
}
export async function getCredits(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    return res.json(await getCustomerCredits(id));
  } catch (err) { return handleError(res, err, 'getCredits'); }
}
export async function postCredit(req: Request, res: Response) {
  try {
    const { saleId, customerId, totalAmount, dueDate } = createCreditSchema.parse(req.body);
    return res.status(201).json(await createReceivableFromSale(saleId, customerId, totalAmount, new Date(dueDate), getUserId(req)));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'postCredit');
  }
}
export async function checkLimit(req: Request, res: Response) {
  try {
    const customerId = getParam(req, 'id');
    const amount = parseFloat(String(req.query['amount'] ?? '0'));
    return res.json(await checkCreditLimit(customerId, amount));
  } catch (err) { return handleError(res, err, 'checkLimit'); }
}
export async function payCreditInstallment(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const { amount, paymentMethod, notes, cashRegisterId } = paymentSchema.parse(req.body);
    return res.json(await recordPayment(id, amount, paymentMethod, getUserId(req), notes, cashRegisterId));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'payCreditInstallment');
  }
}
export async function getWarranties(req: Request, res: Response) {
  try {
    const statusFilter = req.query['status'] as string | undefined;
    const customerId = getParam(req, 'id');
    const warranties = statusFilter === 'all' ? await getAllWarranties(customerId) : await getActiveWarranties(customerId);
    return res.json(warranties);
  } catch (err) { return handleError(res, err, 'getWarranties'); }
}
export async function claimWarranty(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const { notes } = claimSchema.parse(req.body);
    return res.json(await markWarrantyClaimed(id, notes));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'claimWarranty');
  }
}
export async function postCommunication(req: Request, res: Response) {
  try {
    const { customerId, type, message } = communicationSchema.parse(req.body);
    return res.status(201).json(await addCommunicationLog(customerId, type, message, getUserId(req)));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'postCommunication');
  }
}
export async function postMotorcycle(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const data = motorcycleSchema.parse(req.body);
    return res.status(201).json(await addMotorcycle(id, data));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'postMotorcycle');
  }
}
export async function patchMotorcycle(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const data = motorcycleSchema.partial().parse(req.body);
    return res.json(await updateMotorcycle(id, data));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'patchMotorcycle');
  }
}
export async function postReminder(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const { type, message, dueDate } = reminderSchema.parse(req.body);
    return res.status(201).json(await createReminder(id, type, message, new Date(dueDate)));
  } catch (err) {
    if (err instanceof z.ZodError) return res.status(400).json({ error: 'Datos inválidos', details: err.issues });
    return handleError(res, err, 'postReminder');
  }
}
export async function addLoyaltyPoints(req: Request, res: Response) {
  try {
    const id = getParam(req, 'id');
    const { amount } = req.body as { amount: number };
    if (!amount || amount <= 0) return res.status(400).json({ error: 'amount debe ser mayor que cero' });
    return res.json(await calculateLoyalty(id, amount));
  } catch (err) { return handleError(res, err, 'addLoyaltyPoints'); }
}
