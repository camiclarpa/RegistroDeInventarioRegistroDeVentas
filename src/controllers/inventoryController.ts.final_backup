// CATEGORÍAS
// ═══════════════════════════════════════════════════════════════════════════

export async function createCategory(req: Request, res: Response) {
  try {
    const { name, description, codePrefix, isActive } = req.body;
    const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').substring(0, 50);
    const prefix = (codePrefix || name.substring(0, 3).toUpperCase().replace(/[^A-Z0-9]/g, '') || 'CAT').substring(0, 6);
    const category = await prisma.categories.create({
      data: { name, slug, codePrefix: prefix, isActive: isActive ?? true } as any,
    });
    await logAction(req.user?.id ?? 'system', 'CATEGORY_CREATED', 'Category', category.id, { name }, req.ip);
    return res.status(201).json({ success: true, data: category });
  } catch (err) {
    if ((err as any)?.code === 'P2002') {
      const existing = await prisma.categories.findFirst({ where: { name: { equals: req.body.name, mode: 'insensitive' } } });
      if (existing) return res.status(200).json({ success: true, data: existing });
    }
    return handleError(res, err, 'createCategory');
  }
}

