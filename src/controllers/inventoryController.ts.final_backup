export async function updateProduct(req: Request, res: Response) {
  try {
    const id = extractId(req.params['id']!);
    const body = req.body;
    const mapped: any = {};
    if (body.name !== undefined) mapped.nameCommercial = body.name;
    if (body.barcodeExternal !== undefined) mapped.barcodeExternal = body.barcodeExternal;
    if (body.partNumberOEM !== undefined) mapped.partNumberOEM = body.partNumberOEM;
    if (body.brandId !== undefined) mapped.brandId = body.brandId;
    if (body.categoryId !== undefined) mapped.categoryId = body.categoryId;
    if (body.costPriceAvg !== undefined || body.costPrice !== undefined) mapped.costPriceAvg = Number(body.costPriceAvg || body.costPrice);
    if (body.salePriceBase !== undefined || body.salePrice !== undefined) mapped.salePriceBase = Number(body.salePriceBase || body.salePrice);
    if (body.taxRate !== undefined) mapped.taxRate = Number(body.taxRate);
    if (body.stockQuantity !== undefined || body.stock !== undefined) mapped.stockQuantity = Number(body.stockQuantity || body.stock);
    if (body.minStockLevel !== undefined || body.minStock !== undefined) mapped.minStockLevel = Number(body.minStockLevel || body.minStock);
    if (body.locationBin !== undefined) mapped.locationBin = body.locationBin;
    if (body.descriptionTech !== undefined) mapped.descriptionTech = body.descriptionTech;
    if (body.isActive !== undefined) mapped.isActive = body.isActive;
    const input = updateProductSchema.parse(mapped);
    const product = await inventoryService.updateProduct(id, input, req.user?.id);
    await logAction(req.user?.id ?? null, 'UPDATE_PRODUCT', 'Product', id, { changes: mapped }, req.ip);
    return ok(res, serializeProduct(product as any));
  } catch (err) {
    return handleError(res, err, 'updateProduct', req);
  }
}

