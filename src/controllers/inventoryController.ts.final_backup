export async function generateProductCode(req: Request, res: Response) {
  try {
    const { categoryId, category, brandId, brand } = req.body;
    let categoryFound = null;
    if (categoryId) categoryFound = await prisma.categories.findUnique({ where: { id: categoryId }, select: { codePrefix: true } });
    if (!categoryFound && category) categoryFound = await prisma.categories.findFirst({ where: { name: { equals: category.trim() } }, select: { codePrefix: true } });
    if (!categoryFound) return fail(res, 'Categoría no encontrada', 404);
    const categoryPrefix = categoryFound.codePrefix?.toUpperCase() || 'GEN';
    let brandPrefix = 'GEN';
    if (brandId) {
      const brandFound = await prisma.brands.findUnique({ where: { id: brandId }, select: { name: true } });
      if (brandFound?.name) brandPrefix = brandFound.name.substring(0, 3).toUpperCase();
    } else if (brand) {
      const brandFound = await prisma.brands.findFirst({ where: { name: { equals: brand.trim() } }, select: { name: true } });
      if (brandFound?.name) brandPrefix = brandFound.name.substring(0, 3).toUpperCase();
    }
    const consecutive = String(Date.now()).slice(-3);
    const skuInternal = `${categoryPrefix}-${brandPrefix}-${consecutive}`.toUpperCase();
    return ok(res, { skuInternal, barcodeExternal: generateEAN13(), message: 'Códigos generados automáticamente' });
  } catch (error) {
    return fail(res, 'Error del servidor: ' + (error instanceof Error ? error.message : String(error)), 500);
  }
}

export async function exportProducts(req: Request, res: Response) {
  try {
    const products = await prisma.products.findMany({ include: { categories: true, brands: true }, where: { isActive: true } });
    const csv = [['SKU','Nombre','Categoría','Marca','Costo','Venta','Stock','Ubicación'].join(',')];
    for (const p of products) {
      csv.push([p.skuInternal, p.nameCommercial, p.categories?.name || '', p.brands?.name || '', String(p.costPriceAvg), String(p.salePriceBase), String(p.stockQuantity), p.locationBin || ''].join(','));
    }
    res.setHeader('Content-Type', 'text/csv');
    res.setHeader('Content-Disposition', 'attachment; filename=inventario.csv');
    return res.send(csv.join('\n'));
  } catch (error) {
    return res.status(500).json({ success: false, error: 'Error al exportar' });
  }
}

