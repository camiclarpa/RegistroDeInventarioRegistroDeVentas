// ═══════════════════════════════════════════════════════════════════════════
// PRODUCTOS
// ═══════════════════════════════════════════════════════════════════════════

export async function createProduct(req: Request, res: Response) {
  try {
    const body = req.body;
    const resolvedBrandId = body.brandId || await inventoryService.getOrCreateGenericBrand();
    const generateUniqueBarcode = async () => {
      let barcode = body.barcodeExternal || generateEAN13();
      for (let i = 0; i < 10; i++) {
        const existing = await prisma.products.findUnique({ where: { barcodeExternal: barcode } });
        if (!existing) return barcode;
        barcode = generateEAN13();
      }
      return barcode;
    };
    const input = createProductSchema.parse({
      nameCommercial: body.name,
      skuInternal: body.skuInternal || body.sku,
      barcodeExternal: await generateUniqueBarcode(),
      partNumberOEM: body.partNumberOEM || body.name,
      brandId: resolvedBrandId,
      categoryId: body.categoryId,
      costPriceAvg: body.costPriceAvg || body.costPrice,
      salePriceBase: body.salePriceBase || body.salePrice,
      taxRate: body.taxRate,
      stockQuantity: body.stockQuantity || body.stock,
      minStockLevel: body.minStockLevel || body.minStock,
      locationBin: body.locationBin || 'SIN-UBICACION',
      descriptionTech: body.descriptionTech || body.description,
      compatibleModels: body.compatibleModels || [],
      isActive: body.isActive ?? true,
    });
    const product = await inventoryService.createProduct(input, req.user?.id);
    await logAction(req.user?.id ?? null, 'CREATE_PRODUCT', 'Product', product.id, { sku: product.skuInternal, name: product.nameCommercial }, req.ip);
    return ok(res, serializeProduct(product as any), 201);
  } catch (err) {
    return handleError(res, err, 'createProduct', req);
  }
}

export async function getAllProducts(req: Request, res: Response) {
  try {
    const query = getProductsQuerySchema.parse(req.query);
    const result = await inventoryService.getAllProducts(query);
    return ok(res, { data: result.data.map((p) => serializeProduct(p as any)), meta: result.meta });
