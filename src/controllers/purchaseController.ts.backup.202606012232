import crypto from 'crypto';
import { Request, Response } from 'express';
import { prisma } from '../config/prisma';
import { logger } from '../config/logger';
import { Prisma } from '@prisma/client';

const ok = (res: Response, data: unknown, status = 200) =>
  res.status(status).json({ success: true, data });

const fail = (res: Response, error: string, status = 400) =>
  res.status(status).json({ success: false, error });

const getStr = (v: unknown): string | undefined => {
  if (typeof v === 'string') return v;
  if (Array.isArray(v) && typeof v[0] === 'string') return v[0];
  return undefined;
};

const getNum = (v: unknown, def = 0): number => {
  const n = Number(getStr(v));
  return isNaN(n) ? def : n;
};

// ═══════════════════════════════════════════════════════════════════════
// PURCHASE ORDERS
// ═══════════════════════════════════════════════════════════════════════

export async function listPurchaseOrdersHandler(req: Request, res: Response): Promise<Response> {
  try {
    const page = getNum(req.query.page, 1);
    const limit = getNum(req.query.limit, 20);
    const status = getStr(req.query.status);
    const supplierId = getStr(req.query.supplierId);

    const where: Prisma.PurchaseOrderWhereInput = {};
    if (status) where.status = status as any;
    if (supplierId) where.supplierId = supplierId;

    const [data, total] = await prisma.$transaction([
      prisma.purchaseOrder.findMany({
        where,
        include: { 
          supplier: { select: { id: true, name: true } }, 
          items: { include: { product: { select: { id: true, nameCommercial: true, skuInternal: true } } } } 
        },
        orderBy: { createdAt: 'desc' },
        skip: (page - 1) * limit,
        take: limit,
      }),
      prisma.purchaseOrder.count({ where }),
    ]);

    return ok(res, { data, total, totalPages: Math.ceil(total / limit) });
  } catch (err) {
    logger.error('[purchaseController] listPurchaseOrdersHandler', err);
    return fail(res, 'Error al obtener órdenes de compra', 500);
  }
}

export async function getPurchaseOrderByIdHandler(req: Request, res: Response): Promise<Response> {
  try {
    const id = getStr(req.params.id);
    if (!id) return fail(res, 'ID requerido', 400);

    const order = await prisma.purchaseOrder.findUnique({
      where: { id },
      include: { supplier: true, items: { include: { product: true } }, accountPayable: true }
    });
    if (!order) return fail(res, 'Orden no encontrada', 404);
    return ok(res, order);
  } catch (err) {
    logger.error('[purchaseController] getPurchaseOrderByIdHandler', err);
    return fail(res, 'Error al obtener orden', 500);
  }
}

export async function createPurchaseOrderHandler(req: Request, res: Response): Promise<Response> {
  try {
    const { supplierId, items, expectedDate, notes } = req.body;
    const userId = (req.user as any)?.id;

    if (!supplierId || !items?.length) return fail(res, 'Proveedor y al menos un ítem son requeridos', 400);

    const subtotal = items.reduce((s: number, i: any) => s + (Number(i.quantity) * Number(i.unitCost)), 0);
    const taxAmount = subtotal * 0.19;
    const totalAmount = subtotal + taxAmount;

    const last = await prisma.purchaseOrder.findFirst({ orderBy: { createdAt: 'desc' } });
    const num = last ? parseInt(last.orderNumber.split('-').pop() || '0') + 1 : 1;
    const orderNumber = `OC-${new Date().getFullYear()}-${String(num).padStart(5, '0')}`;

    const order = await prisma.purchaseOrder.create({
      data: {
        orderNumber: orderNumber,
        supplierId: supplierId,
        userId: userId,
        status: 'PENDING',
        subtotal: subtotal,
        taxAmount: taxAmount,
        totalAmount: totalAmount,
        expectedDate: expectedDate ? new Date(expectedDate) : null,
        notes: notes,
        items: {
          create: items.map((i: any) => {
            const qty = Number(i.quantity);
            const cost = Number(i.unitCost);
            return {
              productId: i.productId,
              quantityOrdered: qty,
              quantityReceived: 0,
              unitCost: cost,
              lineTotal: qty * cost,
              productNameSnapshot: i.productName || i.name || (i.product && i.product.nameCommercial) || '',
              skuSnapshot: i.sku || i.skuInternal || (i.product && i.product.skuInternal) || ''
            };
          })
        }
      },
      include: { 
        supplier: true, 
        items: { include: { product: true } } 
      }
    });

    return ok(res, order, 201);
  } catch (err) {
    logger.error('[purchaseController] createPurchaseOrderHandler', err);
    return fail(res, 'Error al crear orden', 500);
  }
}

export async function receivePurchaseOrderHandler(req: Request, res: Response): Promise<Response> {
  try {
    const id = getStr(req.params.id);
    const { items } = req.body;
    if (!id || !items?.length) return fail(res, 'ID y items requeridos', 400);

    const order: any = await prisma.purchaseOrder.findUnique({
      where: { id: id },
      include: { items: { include: { product: true } } }
    });
    if (!order) return fail(res, 'Orden no encontrada', 404);
    if (order.status !== 'PENDING') return fail(res, 'Solo órdenes pendientes pueden recibirse', 400);

    await prisma.$transaction(async (tx) => {
      for (const item of items) {
        const oi = (order.items as any[]).find((x) => x.id === item.purchaseOrderItemId);
        if (oi) {
          await tx.product.update({
            where: { id: oi.productId },
            data: { stockQuantity: { increment: Number(item.quantityReceived || oi.quantityOrdered) } }
          });
        }
      }
      await tx.purchaseOrder.update({
        where: { id: id },
        data: { status: 'RECEIVED', receivedDate: new Date() }
      });
    });

    const updated = await prisma.purchaseOrder.findUnique({
      where: { id: id },
      include: { supplier: true, items: { include: { product: true } } }
    });
    return ok(res, updated);
  } catch (err) {
    logger.error('[purchaseController] receivePurchaseOrderHandler', err);
    return fail(res, 'Error al recibir orden', 500);
  }
}

export async function cancelPurchaseOrderHandler(req: Request, res: Response): Promise<Response> {
  try {
    const id = getStr(req.params.id);
    if (!id) return fail(res, 'ID requerido', 400);

    const order = await prisma.purchaseOrder.findUnique({ where: { id: id } });
    if (!order) return fail(res, 'Orden no encontrada', 404);
    if (order.status !== 'PENDING') return fail(res, 'Solo órdenes pendientes pueden cancelarse', 400);

    const updated = await prisma.purchaseOrder.update({
      where: { id: id },
      data: { status: 'CANCELLED' },
      include: { supplier: true, items: { include: { product: true } } }
    });
    return ok(res, updated);
  } catch (err) {
    logger.error('[purchaseController] cancelPurchaseOrderHandler', err);
    return fail(res, 'Error al cancelar orden', 500);
  }
}

// ═══════════════════════════════════════════════════════════════════════
// ENTRIES (Entradas de Almacén)
// ═══════════════════════════════════════════════════════════════════════

export async function registerEntryHandler(req: Request, res: Response): Promise<Response> {
  try {
    const purchaseOrderId = getStr(req.body.purchaseOrderId);
    const { items, notes } = req.body;
    const entryDateStr = getStr(req.body.entryDate);
    const userId = (req.user as any)?.id;

    if (!purchaseOrderId || !items?.length) return fail(res, 'Orden y al menos un ítem requeridos', 400);

    const order: any = await prisma.purchaseOrder.findUnique({
      where: { id: purchaseOrderId },
      include: { items: { include: { product: true } }, supplier: true }
    });
    if (!order) return fail(res, 'Orden no encontrada', 404);
    if (order.status !== 'RECEIVED') return fail(res, 'Solo órdenes recibidas pueden registrarse como entrada', 400);

    const last = await prisma.inventoryMovement.findFirst({
      where: { type: 'ENTRY' },
      orderBy: { timestamp: 'desc' }
    });
    const num = last && last.referenceDoc ? parseInt(last.referenceDoc.split('-').pop() || '0') + 1 : 1;
    const entryNumber = `ENT-${new Date(entryDateStr || Date.now()).getFullYear()}-${String(num).padStart(5, '0')}`;

    const result = await prisma.$transaction(async (tx) => {
      for (const item of items) {
        const oi = (order.items as any[]).find((x) => x.id === item.purchaseOrderItemId);
        if (!oi) continue;
        
        const product = oi.product;
        const qty = Number(item.quantityReceived || oi.quantityOrdered);
        const cost = Number(item.unitCost || oi.unitCost);

        const currStock = product.stockQuantity;
        const currWAC = product.costPriceAvg.toNumber();
        const newWAC = currStock > 0 ? ((currWAC * currStock) + (cost * qty)) / (currStock + qty) : cost;

        await tx.product.update({
          where: { id: product.id },
          data: { stockQuantity: { increment: qty }, costPriceAvg: newWAC }
        });

        await tx.inventoryMovement.create({
          data: {
            productId: product.id,
            type: 'ENTRY',
            quantity: qty,
            unitCostAtMoment: cost,
            referenceDoc: entryNumber,
            reason: notes || `Entrada desde orden ${order.orderNumber}`,
            performedByUserId: userId
          }
        });
      }
      return await tx.purchaseOrder.update({
        where: { id: purchaseOrderId },
        data: { notes: notes ? (order.notes || '') + '\n[ENTRADA] ' + notes : order.notes },
        include: { supplier: true, items: { include: { product: true } } }
      });
    });

    logger.info('[purchaseController] Entrada registrada', { entryNumber, purchaseOrderId });
    return ok(res, { ...result, entryNumber: entryNumber }, 201);
  } catch (err) {
    logger.error('[purchaseController] registerEntryHandler', err);
    return fail(res, err instanceof Error ? err.message : 'Error al registrar entrada', 500);
  }
}

export async function getAllEntriesHandler(req: Request, res: Response): Promise<Response> {
  try {
    const page = getNum(req.query.page, 1);
    const limit = getNum(req.query.limit, 20);
    const startDate = getStr(req.query.startDate);
    const endDate = getStr(req.query.endDate);

    const where: Prisma.InventoryMovementWhereInput = { type: 'ENTRY' };
    
    if (startDate || endDate) {
      where.timestamp = {} as any;
      if (startDate) (where.timestamp as any).gte = new Date(startDate as string);
      if (endDate) (where.timestamp as any).lte = new Date(endDate as string);
    }

    const [movements, total] = await prisma.$transaction([
      prisma.inventoryMovement.findMany({
        where: where,
        orderBy: { timestamp: 'desc' },
        skip: (page - 1) * limit,
        take: limit
      }),
      prisma.inventoryMovement.count({ where: where })
    ]);

    const productIds = [...new Set(movements.map((m: any) => m.productId))];
    const products = productIds.length > 0
      ? await prisma.product.findMany({
          where: { id: { in: productIds } },
          select: { id: true, nameCommercial: true, skuInternal: true, barcodeExternal: true }
        })
      : [];
    const productMap = new Map(products.map(p => [p.id, p]));

    const grouped = movements.reduce((acc: any, m: any) => {
      const key = m.referenceDoc || 'SIN-REF';
      if (!acc[key]) acc[key] = {
        id: key,
        entryNumber: key,
        date: m.timestamp,
        reason: m.reason,
        totalItems: 0,
        totalValue: 0,
        items: []
      };
      const cost = m.unitCostAtMoment?.toNumber() || 0;
      const prod = productMap.get(m.productId);
      acc[key].totalItems += m.quantity;
      acc[key].totalValue += cost * m.quantity;
      acc[key].items.push({ product: prod, quantity: m.quantity, unitCost: cost, totalCost: cost * m.quantity });
      return acc;
    }, {});

    const entries = Object.values(grouped);
    return ok(res, {
      data: entries.slice((page - 1) * limit, page * limit),
      total: entries.length,
      totalPages: Math.ceil(entries.length / limit)
    });
  } catch (err) {
    logger.error('[purchaseController] getAllEntriesHandler', err);
    return fail(res, 'Error al obtener entradas', 500);
  }
}

export async function getEntryByIdHandler(req: Request, res: Response): Promise<Response> {
  try {
    const entryId = getStr(req.params.id);
    if (!entryId) return fail(res, 'ID requerido', 400);

    const whereClause: any = { type: 'ENTRY' };
    if (entryId) whereClause.referenceDoc = { equals: entryId };

    const movements = await prisma.inventoryMovement.findMany({
      where: whereClause,
      orderBy: { timestamp: 'asc' }
    });

    if (!movements.length) return fail(res, 'Entrada no encontrada', 404);

    const productIds = [...new Set(movements.map(m => m.productId))];
    const products = productIds.length > 0
      ? await prisma.product.findMany({
          where: { id: { in: productIds } },
          select: { id: true, nameCommercial: true, skuInternal: true, barcodeExternal: true, costPriceAvg: true, stockQuantity: true }
        })
      : [];
    const productMap = new Map(products.map(p => [p.id, p]));

    const first = movements[0];
    const entry = {
      id: first.referenceDoc,
      entryNumber: first.referenceDoc,
      date: first.timestamp,
      reason: first.reason,
      totalItems: movements.reduce((s: number, m: any) => s + m.quantity, 0),
      totalValue: movements.reduce((s: number, m: any) => {
        const cost = m.unitCostAtMoment?.toNumber() || 0;
        return s + (cost * m.quantity);
      }, 0),
      items: movements.map(m => {
        const cost = m.unitCostAtMoment?.toNumber() || 0;
        const prod = productMap.get(m.productId);
        return {
          product: prod ? {
            id: prod.id,
            name: prod.nameCommercial,
            sku: prod.skuInternal,
            barcode: prod.barcodeExternal,
            currentWAC: prod.costPriceAvg?.toNumber(),
            currentStock: prod.stockQuantity
          } : null,
          quantity: m.quantity,
          unitCost: cost,
          totalCost: cost * m.quantity,
          wacAtEntry: cost
        };
      })
    };
    return ok(res, entry);
  } catch (err) {
    logger.error('[purchaseController] getEntryByIdHandler', err);
    return fail(res, 'Error al obtener entrada', 500);
  }
}


/**
 * GET /api/v1/purchases/orders/:id/pdf
 * Genera y descarga PDF de orden de compra
 */
export async function downloadPurchaseOrderPDFHandler(req: Request, res: Response): Promise<Response> {
  try {
    const id = req.params.id as string;
    
    // Obtener orden con relaciones
    const order = await prisma.purchaseOrder.findUnique({
      where: { id },
      include: { 
        items: { include: { product: true } },
        supplier: true
      }
    });
    
    if (!order) {
      return res.status(404).json({ success: false, message: 'Orden no encontrada' });
    }
    
    // Generar PDF usando pdfkit (ya instalado como dependencia)
    const PDFDocument = require('pdfkit');
    const doc = new PDFDocument({ margin: 40, size: 'A4' });
    
    // Configurar headers para descarga
    res.setHeader('Content-Type', 'application/pdf');
    res.setHeader('Content-Disposition', `attachment; filename=orden-${order.orderNumber}.pdf`);
    
    // Pipe directo a response
    doc.pipe(res);
    
    // === HEADER ===
    doc.fontSize(18).font('Helvetica-Bold').text('ORDEN DE COMPRA', { align: 'center' });
    doc.moveDown(0.5);
    doc.fontSize(10).font('Helvetica').text(`Número: ${order.orderNumber}`, { align: 'center' });
    doc.text(`Fecha: ${new Date(order.createdAt).toLocaleDateString('es-CO')}`, { align: 'center' });
    doc.moveDown(1);
    
    // === PROVEEDOR ===
    doc.font('Helvetica-Bold').fontSize(12).text('Proveedor:');
    doc.font('Helvetica').fontSize(10);
    doc.text(order.supplier?.name || 'N/A');
    if (order.supplier?.nit) doc.text(`NIT: ${order.supplier.nit}`);
    if (order.supplier?.contactPerson) doc.text(`Contacto: ${order.supplier.contactPerson}`);
    if (order.supplier?.phone) doc.text(`Teléfono: ${order.supplier.phone}`);
    doc.moveDown(1);
    
    // === TABLA DE PRODUCTOS ===
    doc.font('Helvetica-Bold').fontSize(10).text('Detalle de Productos:', { underline: true });
    doc.moveDown(0.3);
    
    // Cabecera de tabla
    const tableTop = doc.y;
    doc.font('Helvetica-Bold').fontSize(9);
    doc.text('Producto', 40, tableTop);
    doc.text('Cant.', 250, tableTop);
    doc.text('Costo Unit.', 320, tableTop, { width: 90, align: 'right' });
    doc.text('Subtotal', 430, tableTop, { width: 90, align: 'right' });
    
    // Línea separadora
    doc.moveTo(40, tableTop + 15).lineTo(520, tableTop + 15).stroke();
    doc.moveDown(0.5);
    
    // Filas de productos
    doc.font('Helvetica').fontSize(9);
    let rowY = doc.y;
    order.items.forEach((item: any, idx: number) => {
      const productName = item.product?.name || `Producto ${item.productId}`;
      doc.text(productName.substring(0, 40), 40, rowY, { width: 200 });
      doc.text(item.quantity.toString(), 250, rowY, { width: 60 });
      doc.text(`$${item.unitCost.toLocaleString('es-CO')}`, 320, rowY, { width: 90, align: 'right' });
      doc.text(`$${item.subtotal.toLocaleString('es-CO')}`, 430, rowY, { width: 90, align: 'right' });
      rowY += 15;
    });
    
    // Línea final
    doc.moveTo(40, rowY + 5).lineTo(520, rowY + 5).stroke();
    doc.moveDown(1);
    
    // === TOTALES ===
    doc.font('Helvetica-Bold').fontSize(11);
    // @ts-ignore
    (doc as any).text(`SUBTOTAL: $${order.subtotal.toLocaleString('es-CO')}`, 350, doc.y, { width: 170, align: 'right' });
    doc.moveDown(0.3);
    // @ts-ignore
    (doc as any).text(`TOTAL: $${order.totalAmount.toLocaleString('es-CO')}`, 350, doc.y, { width: 170, align: 'right' });
    
    // === FOOTER ===
    doc.moveDown(2);
    doc.font('Helvetica').fontSize(8).text('----------------------------------------', { align: 'center' });
    doc.text('Documento generado automáticamente por SIGC-Motos', { align: 'center' });
    doc.text(`Generado: ${new Date().toLocaleString('es-CO')}`, { align: 'center' });
    
    // Finalizar PDF
    doc.end();
    
    return res as any;
  } catch (err) {
    logger.error('[purchaseController] downloadPurchaseOrderPDFHandler', err);
    return res.status(500).json({ success: false, message: 'Error al generar PDF' });
  }
}


/**
 * PUT /api/v1/purchases/orders/:id
 * Actualiza una orden de compra (solo si está PENDIENTE)
 */
export async function updatePurchaseOrderHandler(req: Request, res: Response): Promise<Response> {
  try {
    const id = req.params.id as string;
    const { supplierId, items, expectedDate, notes } = req.body;
    
    // Verificar que la orden exista y esté en estado PENDING
    const existing: any = await prisma.purchaseOrder.findUnique({
      where: { id },
      include: { items: true }
    });
    
    if (!existing) {
      return res.status(404).json({ success: false, message: 'Orden no encontrada' });
    }
    
    if (existing.status !== 'PENDING') {
      return res.status(400).json({ 
        success: false, 
        message: 'Solo se pueden editar órdenes en estado PENDIENTE' 
      });
    }
    
    // Calcular nuevos totales
    const newSubtotal = items?.reduce((sum: number, item: any) => 
      sum + (item.quantity * item.unitCost), 0) || 0;
    const newTotal = newSubtotal; // Sin impuestos por ahora
    
    // Actualizar orden
    const updated = await prisma.purchaseOrder.update({
      where: { id },
      data: {
        supplierId: supplierId || existing.supplierId,
        expectedDate: expectedDate || existing.expectedDate,
        notes: notes ?? existing.notes,
        subtotalAmount: newTotal,
        totalAmount: newTotal,
        items: {
          deleteMany: {},
          create: items?.map((item: any) => ({
            productId: item.productId,
            quantity: item.quantity,
            unitCost: item.unitCost,
            subtotal: item.quantity * item.unitCost
          })) || []
        }
      },
      include: { items: true, supplier: true }
    });
    
    return res.json({ success: true, data: updated });
  } catch (err) {
    logger.error('[purchaseController] updatePurchaseOrderHandler', err);
    return res.status(500).json({ success: false, message: 'Error al actualizar orden' });
  }
}
