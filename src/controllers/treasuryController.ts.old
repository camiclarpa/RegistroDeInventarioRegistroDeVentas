// ─── GET /api/v1/treasury/tax-summary ───────────────────────────────────────
export async function getTaxSummary(req: Request, res: Response): Promise<Response> {
  try {
    const now = new Date();
    const month = parseInt(String(req.query['month'] ?? now.getMonth() + 1));
    const year = parseInt(String(req.query['year'] ?? now.getFullYear()));
    if (month < 1 || month > 12 || year < 2020) return fail(res, 'Parámetros inválidos', 400);
    const summary = await taxService.getMonthlyTaxSummary(month, year);
    return ok(res, summary);
  } catch (err) { return handleError(res, err, 'getTaxSummary'); }
}

// ─── POST /api/v1/treasury/withholdings ─────────────────────────────────────
export async function registerWithholding(req: Request, res: Response): Promise<Response> {
  try {
    const { transactionId, type, baseAmount } = req.body;
    if (!transactionId || !type || !baseAmount) return fail(res, 'Campos requeridos', 400);
    if (!Object.values('WITHHOLDING_TYPE').includes(type as 'WITHHOLDING_TYPE')) return fail(res, 'Type inválido', 400);
    const result = await taxService.registerWithholding(transactionId, type as 'WITHHOLDING_TYPE', parseFloat(baseAmount));
    return ok(res, result);
  } catch (err) { return handleError(res, err, 'registerWithholding'); }
}

// ─── GET /api/v1/treasury/withholding-calc ──────────────────────────────────
export async function calculateWithholding(req: Request, res: Response): Promise<Response> {
  try {
    const { type, baseAmount } = req.query as Record<string, string>;
    if (!type || !baseAmount) return fail(res, 'Campos requeridos', 400);
    if (!Object.values('WITHHOLDING_TYPE').includes(type as 'WITHHOLDING_TYPE')) return fail(res, 'Type inválido', 400);
    const calc = taxService.calculateWithholding(parseFloat(baseAmount), type as 'WITHHOLDING_TYPE');
    return ok(res, calc);
  } catch (err) { return handleError(res, err, 'calculateWithholding'); }
}

// ─── POST /api/v1/treasury/budgets ──────────────────────────────────────────
export async function setBudget(req: Request, res: Response): Promise<Response> {
  try {
    const { category, month, year, amount } = req.body;
    if (!category || !month || !year || !amount) return fail(res, 'Campos requeridos', 400);
    if (!Object.values('EXPENSE_CATEGORY').includes(category as 'EXPENSE_CATEGORY')) return fail(res, 'Categoría inválida', 400);
    const budget = await budgetService.setBudget(req.user!.id, { category: category as 'EXPENSE_CATEGORY', month: parseInt(month), year: parseInt(year), amount: parseFloat(amount) });
      return ok(res, budget, 201);
  } catch (err) { return handleError(res, err, 'setBudget'); }
}

// ─── GET /api/v1/treasury/budgets ───────────────────────────────────────────
export async function getBudgetVsActual(req: Request, res: Response): Promise<Response> {
  try {
    const now = new Date();
    const month = parseInt(String(req.query['month'] ?? now.getMonth() + 1));
    const year = parseInt(String(req.query['year'] ?? now.getFullYear()));
    if (month < 1 || month > 12 || year < 2020) return fail(res, 'Parámetros inválidos', 400);
    const result = await budgetService.getBudgetVsActual(month, year);
    return ok(res, result);
  } catch (err) { return handleError(res, err, 'getBudgetVsActual'); }
}

// ─── GET /api/v1/treasury/budgets/alert ─────────────────────────────────────
export async function checkBudgetAlert(req: Request, res: Response): Promise<Response> {
  try {
    const now = new Date();
    const category = req.query['category'] as string;
    const month = parseInt(String(req.query['month'] ?? now.getMonth() + 1));
    const year = parseInt(String(req.query['year'] ?? now.getFullYear()));
    if (!category || !Object.values('EXPENSE_CATEGORY').includes(category as 'EXPENSE_CATEGORY')) return fail(res, 'Categoría requerida', 400);
    const alert = await budgetService.checkBudgetAlert(category as month, year);
    return ok(res, alert);
  } catch (err) { return handleError(res, err, 'checkBudgetAlert'); }
}

