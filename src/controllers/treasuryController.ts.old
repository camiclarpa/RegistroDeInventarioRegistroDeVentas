// ─── POST /api/v1/treasury/bank-transfers ───────────────────────────────────
export async function createBankTransfer(req: Request, res: Response): Promise<Response> {
  try {
    const { fromAccount, toAccount, amount, reference, description } = req.body;
    if (!fromAccount || !toAccount || !amount || !description) return fail(res, 'Campos requeridos', 400);
    const transfer = await bankingService.createBankTransfer(req.user!.id, { fromAccount, toAccount, amount: parseFloat(amount), reference, description });
    return ok(res, transfer, 201);
  } catch (err) { return handleError(res, err, 'createBankTransfer'); }
}

