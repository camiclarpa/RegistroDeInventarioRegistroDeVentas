export async function getCashFlowProjection(req: Request, res: Response): Promise<Response> {
  try {
    const rawDays = req.query['days'];
    const days = typeof rawDays === 'string' ? Math.min(30, Math.max(1, parseInt(rawDays))) : 7;
    const projection = await cashFlowService.getCashFlowProjection(days);
    return ok(res, projection);
  } catch (err) { return handleError(res, err, 'getCashFlowProjection'); }
}

