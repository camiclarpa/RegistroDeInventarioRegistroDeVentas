// ─── GET /api/v1/treasury/cash-counts ───────────────────────────────────────
export async function getCashCounts(req: Request, res: Response): Promise<Response> {
  try {
    const page = Math.max(1, parseInt(String(req.query['page'] ?? '1')));
    const limit = Math.min(100, parseInt(String(req.query['limit'] ?? '20')));
    const skip = (page - 1) * limit;

    const counts = await prisma.cash_counts.findMany({
      skip,
      take: limit,
      orderBy: { countedAt: 'desc' },
    });

    const total = await prisma.cash_counts.count();

    return ok(res, {
      data: counts,
      meta: { total, page, limit, totalPages: Math.ceil(total / limit) },
    });
  } catch (err) {
    return handleError(res, err, 'getCashCounts');
  }
}

