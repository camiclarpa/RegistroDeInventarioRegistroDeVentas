// ─── GET /api/v1/treasury/cash-register ─────────────────────────────────────
export async function getCashRegisters(req: Request, res: Response): Promise<Response> {
  try {
    const page = Math.max(1, parseInt(String(req.query['page'] ?? '1')));
    const limit = Math.min(100, Math.max(1, parseInt(String(req.query['limit'] ?? '20'))));
    const [registers, total] = await Promise.all([
      prisma.cash_registers.findMany({
        skip: (page - 1) * limit,
        take: limit,
        orderBy: { openedAt: 'desc' },
        include: {
          openedBy: { select: { id: true, name: true } },
          closedBy: { select: { id: true, name: true } },
        },
      }),
      prisma.cash_registers.count(),
    ]);
    return ok(res, { registers, total, page, limit, totalPages: Math.ceil(total / limit) });
  } catch (err) {
    return handleError(res, err, 'getCashRegisters');
  }
}

// ─── GET /api/v1/treasury/transactions ──────────────────────────────────────
export async function getTransactions(req: Request, res: Response): Promise<Response> {
  try {
    const cashRegisterId = req.query['cashRegisterId'] as string | undefined;
    const page = Math.max(1, parseInt(String(req.query['page'] ?? '1')));
      const activeShift = null;
    const limit = Math.min(100, Math.max(1, parseInt(String(req.query['limit'] ?? '50'))));
    const where: any = {};
    if (cashRegisterId) {
      where.cashRegisterId = cashRegisterId;
    } else {
      const activeShift = await treasuryService.getActiveShiftForUser((req.user as any)?.id);
      if (activeShift) {
        where.cashRegisterId = activeShift.id;
      } else {
        return ok(res, { transactions: [], total: 0, page, limit, totalPages: 0 });
      }
    }
    const [transactions, total] = await Promise.all([
      prisma.financial_transactions.findMany({
        where,
        skip: (page - 1) * limit,
        take: limit,
        orderBy: { timestamp: 'desc' },
        include: { performedBy: { select: { id: true, name: true } } },
      }),
      prisma.financial_transactions.count({ where }),
    ]);
    return ok(res, { transactions, total, page, limit, totalPages: Math.ceil(total / limit) });
  } catch (err) {
    return handleError(res, err, 'getTransactions');
  }
}

// ─── POST /api/v1/treasury/deposits ─────────────────────────────────────────
export async function createDeposit(req: Request, res: Response): Promise<Response> {
  try {
    const { amount, bankName, accountNumber, reference, depositDate, notes, cashRegisterId } = req.body;
    if (!amount || !bankName || !depositDate) return fail(res, 'amount, bankName y depositDate son requeridos', 400);
    const deposit = await bankingService.createDeposit((req.user as any)?.id, {
      amount: parseFloat(amount),
      bankName,
      accountNumber,
      reference,
      depositDate: new Date(depositDate),
      notes,
      cashRegisterId,
    });
    return ok(res, deposit, 201);
  } catch (err) {
    return handleError(res, err, 'createDeposit');
  }
}

// ─── GET /api/v1/treasury/deposits ──────────────────────────────────────────
export async function getDeposits(req: Request, res: Response): Promise<Response> {
  try {
    const rawDate = req.query['date'] as string;
    const date = rawDate && /^\d{4}-\d{2}-\d{2}$/.test(rawDate) ? rawDate : undefined;
    const deposits = await bankingService.getDeposits(date);
    return ok(res, deposits);
  } catch (err) {
    return handleError(res, err, 'getDeposits');
