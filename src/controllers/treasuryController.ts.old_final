// ─── PATCH /api/v1/treasury/deposits/:id/status ─────────────────────────────
export async function updateDepositStatus(req: Request, res: Response): Promise<Response> {
  try {
    const { id } = req.params;
    const { status } = req.body;
    if (!status) return fail(res, 'Status requerido', 400);
    const updated = await bankingService.updateDepositStatus(id, status);
    return ok(res, updated);
  } catch (err) {
    return handleError(res, err, 'updateDepositStatus');
  }
}

// ─── POST /api/v1/treasury/bank-transfers ───────────────────────────────────
export async function createBankTransfer(req: Request, res: Response): Promise<Response> {
  try {
    const { fromAccount, toAccount, amount, reference, description } = req.body;
    if (!fromAccount || !toAccount || !amount || !description) return fail(res, 'Campos requeridos', 400);
    const transfer = await bankingService.createBankTransfer((req.user as any)?.id, {
      fromAccount,
      toAccount,
      amount: parseFloat(amount),
      reference,
      description,
    });
    return ok(res, transfer, 201);
  } catch (err) {
    return handleError(res, err, 'createBankTransfer');
  }
}

