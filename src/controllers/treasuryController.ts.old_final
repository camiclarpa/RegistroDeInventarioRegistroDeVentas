// ─── GET /api/v1/treasury/tax-summary ───────────────────────────────────────
export async function getTaxSummary(req: Request, res: Response): Promise<Response> {
  try {
    const now = new Date();
    const month = parseInt(String(req.query['month'] ?? now.getMonth() + 1));
    const year = parseInt(String(req.query['year'] ?? now.getFullYear()));
    if (month < 1 || month > 12 || year < 2020) return fail(res, 'Parámetros inválidos', 400);
    const summary = await taxService.getMonthlyTaxSummary(month, year);
    return ok(res, summary);
  } catch (err) {
    return handleError(res, err, 'getTaxSummary');
  }
}

// ─── POST /api/v1/treasury/withholdings ─────────────────────────────────────
export async function registerWithholding(req: Request, res: Response): Promise<Response> {
  try {
    const { transactionId, type, baseAmount } = req.body;
    if (!transactionId || !type || !baseAmount) return fail(res, 'Campos requeridos', 400);
    const result = await taxService.registerWithholding(transactionId, type, parseFloat(baseAmount));
    return ok(res, result);
  } catch (err) {
    return handleError(res, err, 'registerWithholding');
  }
}

// ─── GET /api/v1/treasury/withholding-calc ──────────────────────────────────
export async function calculateWithholding(req: Request, res: Response): Promise<Response> {
  try {
    const { type, baseAmount } = req.query;
    if (!type || !baseAmount) return fail(res, 'Campos requeridos', 400);
    const calc = taxService.calculateWithholding(parseFloat(baseAmount as string), type as string);
    return ok(res, calc);
  } catch (err) {
    return handleError(res, err, 'calculateWithholding');
  }
}

// ─── POST /api/v1/treasury/budgets ──────────────────────────────────────────
export async function setBudget(req: Request, res: Response): Promise<Response> {
  try {
    const { category, month, year, amount } = req.body;
    if (!category || !month || !year || !amount) return fail(res, 'Campos requeridos', 400);
    const budget = await budgetService.setBudget((req.user as any)?.id, {
      category,
      month: parseInt(month),
      year: parseInt(year),
      amount: parseFloat(amount),
    });
    return ok(res, budget, 201);
  } catch (err) {
    return handleError(res, err, 'setBudget');
  }
}

