import { TransactionType } from '@prisma/client';
import { prisma } from '../config/prisma';
import { logger } from '../config/logger';

// ─── Helpers ─────────────────────────────────────────────────────────────────

function toFloat(value: unknown): number {
  return parseFloat(String(value ?? 0)) || 0;
}

// ─── Abrir caja ───────────────────────────────────────────────────────────────

export async function openCashRegister(
  userId: string,
  openingBalance: number,
  notes?: string,
) {
  const existing = await prisma.cash_registers.findFirst({
    where: { status: 'OPEN' },
    select: { id: true, openedAt: true, openedBy: { select: { name: true } } },
  });

  if (existing) {
    throw new Error(
      `Ya hay una caja abierta (ID: ${existing.id}, abierta por ${existing.openedBy.name}). Ciérrala antes de abrir una nueva.`,
    );
  }

  const register = await prisma.cash_registers.create({
    data: {
      openedByUserId: userId,
      openingBalance: openingBalance,
      status: 'OPEN',
      openedAt: new Date(),
      notes,
    },
    include: { openedByUser: { select: { id: true, name: true, email: true } } },
  });

  logger.info(`[cashRegisterService] Caja abierta: ${register.id} — $${openingBalance}`);
  return register;
}

// ─── Cerrar caja ──────────────────────────────────────────────────────────────

export async function closeCashRegister(
  cashRegisterId: string,
  closingBalance: number,
  userId: string,
  notes?: string,
) {
  const register = await prisma.cash_registers.findUnique({
    where: { id: cashRegisterId },
    select: { id: true, status: true, openingBalance: true, notes: true },
  });

  if (!register) throw new Error('Caja no encontrada');
  if (register.status === 'CLOSED') {
    throw new Error('Esta caja ya fue cerrada');
  }

  // Calcular entradas y salidas mediante agregaciones (eficiente, sin cargar todos los registros)
  const [incomeAgg, expenseAgg] = await Promise.all([
    prisma.financial_transactions.aggregate({
      where: {
        cashRegisterId,
        type: { in: ['INCOME'] },
      },
      _sum: { amount: true },
    }),
    prisma.financial_transactions.aggregate({
      where: {
        cashRegisterId,
        type: {
          in: [
            'EXPENSE',
            'WITHDRAWAL',
            'DEPOSIT',
            'PAYMENT_MADE',
          ],
        },
      },
      _sum: { amount: true },
    }),
  ]);

  const totalIncome  = toFloat(incomeAgg._sum.amount);
  const totalExpense = toFloat(expenseAgg._sum.amount);
  const expectedBalance =
    toFloat(register.initialBalance) + totalIncome - totalExpense;
  const difference = closingBalance - expectedBalance;

  const closed = await prisma.cash_registers.update({
    where: { id: cashRegisterId },
    data: {
      closedByUserId:         userId,
      closingBalance:         closingBalance,
      expectedClosingBalance: expectedBalance,
      difference:             difference,
      status:                 'CLOSED',
      closedAt:               new Date(),
      notes:                  notes ?? register.notes,
    },
    include: {
      openedBy: { select: { id: true, name: true } },
      closedBy: { select: { id: true, name: true } },
      _count:   { select: { transactions: true } },
    },
  });

  logger.info(
    `[cashRegisterService] Caja cerrada: ${cashRegisterId} — diferencia: $${difference}`,
  );

  return {
    ...closed,
    summary: {
      openingBalance:         toFloat(register.initialBalance),
      totalIncome:            parseFloat(totalIncome),
      totalExpense:           parseFloat(totalExpense),
      expectedClosingBalance: parseFloat(expectedBalance),
      closingBalance:         closingBalance,
      difference:             parseFloat(difference),
      differenceStatus:
        difference === 0
          ? ('EXACT' as const)
          : difference > 0
            ? ('SURPLUS' as const)
            : ('SHORTAGE' as const),
    },
  };
}

// ─── Obtener caja abierta ─────────────────────────────────────────────────────

export async function getCurrentOpenRegister() {
  return prisma.cash_registers.findFirst({
    where: { status: 'OPEN' },
    include: {
      openedBy: { select: { id: true, name: true } },
      _count: { select: { transactions: true } },
    },
  });
}

// ─── Resumen de caja ──────────────────────────────────────────────────────────

export async function getCashRegisterSummary(cashRegisterId: string) {
  const register = await prisma.cash_registers.findUnique({
    where: { id: cashRegisterId },
    include: {
      openedBy: { select: { id: true, name: true } },
      closedBy: { select: { id: true, name: true } },
    },
  });
  if (!register) throw new Error('Caja no encontrada');

  const byType = await prisma.financial_transactions.groupBy({
    by: ['type'],
    where: { cashRegisterId },
    _sum: { amount: true },
    _count: { id: true },
  });

  const transactions = await prisma.financial_transactions.findMany({
    where: { cashRegisterId },
    orderBy: { timestamp: 'desc' },
    take: 20,
    include: { performedByUser: { select: { id: true, name: true } } },
  });

  return {
    register,
    breakdown: byType.map((r) => ({
      type: r.type,
      total: toFloat(r._sum.amount),
      count: r._count.id,
    })),
    recentTransactions: transactions,
  };
}

// ─── Historial de cajas ───────────────────────────────────────────────────────

export async function listCashRegisters(limit = 20) {
  return prisma.cash_registers.findMany({
    orderBy: { openedAt: 'desc' },
    take: limit,
    include: {
      openedBy: { select: { id: true, name: true } },
      closedBy: { select: { id: true, name: true } },
      _count: { select: { transactions: true } },
    },
  });
}
